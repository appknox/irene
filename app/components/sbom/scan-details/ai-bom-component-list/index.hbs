<div class='ai-bom-component-list' data-test-sbomScanDetails-aiBomComponentList>
  {{#if this.showAiBomNewFeaturePrompt}}
    {{! Files scanned before AI BoM detection existed get a dedicated,
      standalone empty state -- deliberately NOT using
      Sbom::EmptyLoadingView here, since that shared component's own
      bordered box is used by both this tab and the SBOM tab's populated
      view; styling it from outside risks leaking into those. }}
    <div
      local-class='pre-ai-bom-empty'
      data-test-sbomScanDetails-aiBomComponentListing-container
    >
      <AkStack @direction='column' @alignItems='center' @spacing='1.5'>
        <div
          local-class='new-feature-svg-wrapper'
          data-test-sbomScanDetails-aiBomComponent-newFeatureSvg
        >
          <svg
            width='177'
            height='110'
            viewBox='0 0 177 110'
            fill='none'
            xmlns='http://www.w3.org/2000/svg'
          >
            <g clip-path='url(#clip0_aibom_new_feature)'>
              <path
                d='M139.217 24.1802C139.217 24.1802 134.284 -14.3464 105.181 13.3525C67.8739 48.8585 42.7963 -21.7103 15.1206 7.09512C0.000741639 22.8314 39.9546 58.0252 13.2711 76.5465C-13.4125 95.0677 8.39281 108.934 8.39281 108.934H159.909C159.909 108.934 175.594 110.064 176.782 90.253C177.967 70.4418 159.734 70.2018 171.05 45.41C182.366 20.6183 142.773 39.9602 139.217 24.1802Z'
                fill='#2DB421'
                fill-opacity='0.1'
              />
              <path
                d='M8.20068 108.698H175.478'
                stroke='#424651'
                stroke-width='1.61896'
                stroke-miterlimit='10'
              />
            </g>
            <path
              d='M88.4863 48.1523L85.5361 62.9147L70.7556 59.9777L88.4863 48.1523Z'
              fill='#424651'
              stroke='#424651'
              stroke-width='1.61896'
              stroke-miterlimit='10'
              stroke-linecap='round'
              stroke-linejoin='round'
            />
            <path
              d='M113.219 63.2174V103.378C113.219 106.106 110.958 108.363 108.226 108.363H107.001H67.9937C65.2613 108.363 63 106.106 63 103.378V54.4705V53.1538C63 50.4262 65.2613 48.1689 67.9937 48.1689H98.144'
              fill='white'
            />
            <path
              d='M113.219 63.2174V103.378C113.219 106.106 110.958 108.363 108.226 108.363H107.001H67.9937C65.2613 108.363 63 106.106 63 103.378V54.4705V53.1538C63 50.4262 65.2613 48.1689 67.9937 48.1689H98.144'
              stroke='#424651'
              stroke-width='1.61896'
              stroke-miterlimit='10'
              stroke-linecap='round'
              stroke-linejoin='round'
            />
            <g clip-path='url(#clip1_aibom_new_feature)'>
              <path
                d='M97.575 78.7137C96.7817 74.6887 93.2467 71.667 89 71.667C85.6283 71.667 82.7 73.5803 81.2417 76.3803C77.73 76.7537 75 79.7287 75 83.3337C75 87.1953 78.1383 90.3337 82 90.3337H97.1667C100.387 90.3337 103 87.7203 103 84.5003C103 81.4203 100.608 78.9237 97.575 78.7137ZM91.3333 82.167V86.8337H86.6667V82.167H83.1667L89 76.3337L94.8333 82.167H91.3333Z'
                fill='#2DB421'
              />
            </g>
            <path
              d='M98.5391 48.1689V63.2174H113.614L98.5391 48.1689Z'
              fill='#424651'
              stroke='#424651'
              stroke-width='1.61896'
              stroke-miterlimit='10'
              stroke-linecap='round'
              stroke-linejoin='round'
            />
            <defs>
              <clipPath id='clip0_aibom_new_feature'>
                <rect width='177' height='109' fill='white' />
              </clipPath>
              <clipPath id='clip1_aibom_new_feature'>
                <rect
                  width='28'
                  height='28'
                  fill='white'
                  transform='translate(75 67)'
                />
              </clipPath>
            </defs>
          </svg>
        </div>

        <AkStack
          @direction='column'
          @alignItems='center'
          @spacing='1'
          data-test-sbomScanDetails-aiBomComponent-newFeatureText
        >
          <AkTypography
            data-test-sbomScanDetails-aiBomComponent-newFeatureTitle
            @variant='h6'
          >
            {{t 'sbomModule.aiBomNewFeatureEmptyText.title'}}
          </AkTypography>

          <AkTypography
            data-test-sbomScanDetails-aiBomComponent-newFeatureDescription
            @color='textSecondary'
          >
            {{t 'sbomModule.aiBomNewFeatureEmptyText.description'}}
          </AkTypography>
        </AkStack>
      </AkStack>
    </div>
  {{else}}
    {{! Summary bar with counts }}
    <Sbom::ScanDetails::SummaryBar
      @items={{this.summaryItems}}
      class='mt-3 mb-3'
    />

    <div local-class='listing-container' data-test-sbomScanDetails-aiBomComponentListing-container>
      {{! Search bar }}
      <div class='search-container p-2' {{style width='180px'}}>
        <AkTextField
          data-test-sbomScanDetails-aiBomComponentSearch
          @placeholder={{t 'search'}}
          @value={{this.searchQuery}}
          {{on 'input' this.handleSearchInput}}
        >
          <:leftAdornment>
            <AkIcon @iconName='search' @color='textSecondary' />
          </:leftAdornment>
        </AkTextField>
      </div>

      <AkPaginationProvider
        @results={{this.sbomComponentList}}
        @onItemPerPageChange={{this.handleItemPerPageChange}}
        @totalItems={{this.totalAiBomComponentCount}}
        @nextAction={{this.handlePrevNextAction}}
        @prevAction={{this.handlePrevNextAction}}
        @itemPerPageOptions={{array 10 25 50}}
        @defaultLimit={{this.limit}}
        @offset={{this.offset}}
        as |pgc|
      >
        <Sbom::EmptyLoadingView
          @empty={{this.isEmptyAndNoFilterApplied}}
          @loading={{this.isFetchingSbomComponentList}}
          @skeleton={{true}}
          @height='500px'
        >
          <:emptySvg>
            <AkSvg::NoResult data-test-sbomScanDetails-aiBomComponent-emptySvg />
          </:emptySvg>

          <:emptyText>
            <AkTypography
              data-test-sbomScanDetails-aiBomComponent-emptyTextTitle
              @variant='h6'
            >
              {{this.tNoComponentsFound}}
            </AkTypography>
          </:emptyText>

          <:default>
            <AkTable
              @hoverable={{true}}
              data-test-sbomScanDetails-aiBomComponentTable
              as |t|
            >
              <t.head
                @columns={{this.columns}}
                data-test-sbomScanDetails-aiBomComponentThead
                as |h|
              >
                <h.row as |r|>
                  <r.cell as |column|>
                    {{#if column.headerComponent}}
                      {{#let (component column.headerComponent) as |Component|}}
                        <Component
                          @onAiArtifactClassChange={{this.onAiArtifactClassChange}}
                          @selectedAiArtifactClass={{this.selectedAiArtifactClass}}
                        />
                      {{/let}}
                    {{else}}
                      {{column.name}}
                    {{/if}}
                  </r.cell>
                </h.row>
              </t.head>

              <t.body @rows={{pgc.currentPageResults}} as |b|>
                <b.row
                  {{style cursor='pointer'}}
                  @onClick={{this.handleComponentClick}}
                  data-test-sbomScanDetails-aiBomComponentRow
                  as |r|
                >
                  <r.cell
                    data-test-sbomScanDetails-aiBomComponentCell
                    as |value|
                  >
                    <AkTypography title={{value}} @noWrap={{true}}>
                      {{value}}
                    </AkTypography>
                  </r.cell>
                </b.row>
              </t.body>
            </AkTable>

            {{#if this.isEmptyAndFilterApplied}}
              <AkStack
                @direction='column'
                @alignItems='center'
                @justifyContent='center'
                @spacing='1'
                class='py-5'
              >
                <AkSvg::NoResult data-test-sbomScanDetails-aiBomComponent-noFilterResultSvg />

                <AkTypography
                  data-test-sbomScanDetails-aiBomComponent-noFilterResultText
                  @variant='h6'
                >
                  {{this.tNoComponentsFoundFilter}}
                </AkTypography>
              </AkStack>
            {{/if}}

            <AkPagination
              @disableNext={{pgc.disableNext}}
              @nextAction={{pgc.nextAction}}
              @disablePrev={{pgc.disablePrev}}
              @prevAction={{pgc.prevAction}}
              @endItemIdx={{pgc.endItemIdx}}
              @startItemIdx={{pgc.startItemIdx}}
              @itemPerPageOptions={{pgc.itemPerPageOptions}}
              @onItemPerPageChange={{pgc.onItemPerPageChange}}
              @selectedOption={{pgc.selectedOption}}
              @tableItemLabel={{t 'sbomModule.aiBomComponents'}}
              @perPageTranslation={{t 'recordPerPage'}}
              @totalItems={{pgc.totalItems}}
            />
          </:default>
        </Sbom::EmptyLoadingView>
      </AkPaginationProvider>
    </div>
  {{/if}}

  {{! Component details drawer }}
  <Sbom::ScanDetails::AiBomComponentDrawer
    @component={{this.selectedComponent}}
    @open={{this.openComponentDrawer}}
    @onClose={{this.handleDrawerClose}}
  />
</div>
