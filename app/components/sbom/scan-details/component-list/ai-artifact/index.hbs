{{#if this.aiLabel}}
  <AkStack @direction='row' @alignItems='center' @spacing='2'>
    <AkTypography @noWrap={{true}}>
      {{this.aiLabel}}
    </AkTypography>
    {{#if this.confidenceLabel}}
      <AkChip
        @label={{this.confidenceLabel}}
        @color={{this.confidenceColor}}
        @size='small'
        @variant='filled'
      />
    {{/if}}
  </AkStack>
{{else}}
  <AkTypography @color='textSecondary'>
    -
  </AkTypography>
{{/if}}
