<AkButton
  @variant='filled'
  {{on 'click' this.openSampleDrawer}}
  data-test-projectSettings-viewScenarioHeader-viewSampleBtn
>
  {{t 'dastAutomation.viewSample'}}
</AkButton>

<AkDrawer
  @open={{this.showSampleDrawer}}
  @onClose={{this.closeSampleDrawer}}
  @anchor='right'
  data-test-projectSettings-viewScenarioHeader-sampleDrawer
  as |dr|
>
  <div {{style width='950px' height='100%'}}>
    <AkAppbar @justifyContent='space-between' as |ab|>
      <AkTypography
        @variant='h5'
        @color='inherit'
        data-test-projectSettings-viewScenarioHeader-sampleDrawerTitle
      >
        {{t 'dastAutomation.viewSample'}}
      </AkTypography>

      <AkIconButton
        class={{ab.classes.defaultIconBtn}}
        {{on 'click' dr.closeHandler}}
        data-test-projectSettings-viewScenarioHeader-sampleDrawerCloseBtn
      >
        <AkIcon @iconName='close' />
      </AkIconButton>
    </AkAppbar>

    {{#if this.mockRole}}
      <div class='p-4'>
        <ProjectSettings::DastAutomation::ScenarioViewV2::StepsTable
          @userRole={{this.mockRole}}
          @steps={{this.mockSteps}}
          @scenarioDetail={{@scenarioDetail}}
          @isReadOnly={{true}}
          @isLastRole={{true}}
          @activeSampleIndex={{2}}
          class='px-4 py-3'
        />

        <AkStack
          @direction='column'
          @spacing='1.5'
          class='pt-3'
          data-test-projectSettings-viewScenarioHeader-sampleDrawerNotes
        >
          <AkTypography @variant='body1' @fontWeight='bold' class='mb-2'>
            Note
          </AkTypography>

          <ol local-class='notes-list'>
            <li>
              <AkTypography @variant='body2'>
                <strong>On button/field</strong>
                is the name of the control to act on (e.g.
                <code>email</code>,
                <code>password</code>,
                <code>terms</code>). Max 64 characters.
              </AkTypography>
            </li>

            <li>
              <AkTypography @variant='body2'>
                <strong>Enter Input</strong>,
                <strong>Select</strong>,
                <strong>Swipe</strong>, and
                <strong>Wait</strong>
                require a value.
                <strong>Tap</strong>,
                <strong>Long Press</strong>, and
                <strong>Check</strong>
                are optional.
              </AkTypography>
            </li>

            <li>
              <AkTypography @variant='body2'>
                Changing a row's action clears its
                <strong>On button/field</strong>
                and
                <strong>Input value</strong>.
              </AkTypography>
            </li>

            <li>
              <AkTypography @variant='body2'>
                Use the
                <strong>lock</strong>
                icon to mask sensitive values like passwords — they're stored
                encrypted.
              </AkTypography>
            </li>

            <li>
              <AkTypography @variant='body2'>
                Drag the handle on the left of a row to reorder; use the
                <strong>delete</strong>
                icon on the right to remove it. Steps run top to bottom.
              </AkTypography>
            </li>

            <li>
              <AkTypography @variant='body2'>
                Login scenarios support up to
                <strong>three roles</strong>, each with up to
                <strong>ten steps</strong>.
              </AkTypography>
            </li>
          </ol>
        </AkStack>
      </div>
    {{/if}}
  </div>
</AkDrawer>