<FreestyleSection @name='Appbar'>
  <FreestyleUsage @slug='ak-appbar-basic' @title='Basic'>
    <AkAppbar
      @color='inherit'
      @elevation={{false}}
      @position='static'
      @placement='top'
      @direction='row'
      @alignItems='center'
      @gutter={{true}}
      @justifyContent='space-between'
      @spacing={{0}}
      as |ab|
    >
      <AkTypography @variant='h5' @color='inherit'>Appbar title</AkTypography>
      <AkIconButton class={{ab.classes.defaultIconBtn}}>
        <AkIcon @iconName='close' />
      </AkIconButton>
    </AkAppbar>
  </FreestyleUsage>
</FreestyleSection>
