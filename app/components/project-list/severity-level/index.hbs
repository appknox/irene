<AkStack @spacing='1'>
  {{#each this.severityLevelCounts as |slc|}}
    <AkTooltip @arrow={{true}} @title={{slc.name}} @placement='bottom'>
      <AkStack
        @width='full'
        @justifyContent='space-between'
        @spacing='1'
        local-class='severity-level-tag'
      >
        <AkStack
          @width='full'
          @alignItems='center'
          data-test-fileChart-severityCountGroup='{{slc.name}}'
        >
          <div
            local-class='severity-indicator severity-{{slc.severityType}}'
            data-test-fileChartSeverityLevel-severityCountIndicator
          />

          <AkTypography
            data-test-fileChartSeverityLevel-severityCountValue
            @variant='subtitle1'
            @align='right'
            class='pl-1'
          >
            {{slc.value}}
          </AkTypography>
        </AkStack>
      </AkStack>
    </AkTooltip>
  {{/each}}
</AkStack>