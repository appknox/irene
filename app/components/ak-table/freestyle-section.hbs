<FreestyleSection @name='Table'>
  <FreestyleUsage @slug='ak-table-default' @title='Default' @source='<AkTable @dense=\{{false}} @headerColor="neutral" @borderColor="light" @hoverable=\{{false}} as |t|>
  <t.head @columns=\{{this.columns}} as |h|>
    <h.row as |r|>
      <r.cell as |column|>\{{column.name}}</r.cell>
    </h.row>
  </t.head>
  <t.body @rows=\{{this.rows}} as |b|>
    <b.row as |r|>
      <r.cell as |value|>\{{value}}</r.cell>
    </b.row>
  </t.body>
</AkTable>'>
    <AkTable::FreestyleDemo />
  </FreestyleUsage>

  <FreestyleUsage @slug='ak-table-full-bordered' @title='Full Bordered' @source='<AkTable @dense=\{{false}} @headerColor="neutral" @borderColor="light" @variant="full-bordered" as |t|>
  <t.head @columns=\{{this.columns}} as |h|>
    <h.row as |r|>
      <r.cell as |column|>\{{column.name}}</r.cell>
    </h.row>
  </t.head>
  <t.body @rows=\{{this.rows}} as |b|>
    <b.row as |r|>
      <r.cell as |value|>\{{value}}</r.cell>
    </b.row>
  </t.body>
</AkTable>'>
    <AkTable::FreestyleDemo @variant='full-bordered' />
  </FreestyleUsage>
</FreestyleSection>
