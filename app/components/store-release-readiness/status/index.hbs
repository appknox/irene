<div
  local-class={{if
    @transparentBackground
    'status-wrapper-transparent'
    'status-wrapper'
  }}
  class={{if @transparentBackground 'py-2' 'py-6'}}
  data-test-store-release-readiness-status
>
  <AkStack
    @direction='column'
    @alignItems='center'
    @width='full'
    class={{if @transparentBackground 'py-2' 'py-6 my-6'}}
  >
    {{#let (component @svgComponent) as |SvgComponent|}}
      <SvgComponent />
    {{/let}}

    <AkStack
      class='mt-3'
      @direction='column'
      @alignItems='center'
      @spacing='1.5'
      local-class='text-width'
    >
      <AkTypography
        @align='center'
        @variant='h5'
        data-test-store-release-readiness-status-heading
      >
        {{@heading}}
      </AkTypography>

      <AkTypography
        @align='center'
        data-test-store-release-readiness-status-description
      >
        {{@description}}
      </AkTypography>
    </AkStack>
  </AkStack>
</div>