<div local-class='edit-policy-details-content'>
  {{#unless @isOverridden}}
    <AkTypography class='px-3 pt-2'>
      {{t 'storeReleaseReadiness.overrideIgnoreConfirmPrompt'}}
    </AkTypography>
  {{/unless}}

  <AkStack @justifyContent='space-between' @alignItems='center' class='p-3'>
    <AkStack @direction='column' @spacing='0.5'>
      <AkTypography
        @color='textSecondary'
        @fontWeight='medium'
        @tag='h6'
        {{style fontSize='0.857rem' textTransform='uppercase'}}
        data-test-store-release-readiness-policy-details-category
      >
        {{@category}}
      </AkTypography>

      <AkTypography
        @variant='subtitle1'
        class='mr-5'
        data-test-store-release-readiness-policy-details-title
      >
        {{@title}}
      </AkTypography>
    </AkStack>

    <div data-test-store-release-readiness-policy-details-status-cell>
      <StoreReleaseReadiness::ScanResults::AssessmentTable::StatusCell
        @data={{@statusData}}
        @showOverriddenEditIcon={{false}}
        data-test-store-release-readiness-assessment-status-cell
      />
    </div>
  </AkStack>

  <div class='pb-2 px-3'>
    <AkStack @direction='column' @spacing='1'>
      <AkTypography
        @variant='h6'
        @color='textSecondary'
        @tag='label'
        for='store-release-readiness-policy-override-reason-field'
        {{style fontSize='0.857rem'}}
        data-test-store-release-readiness-policy-details-override-reason-label
      >
        {{t 'reason'}}
      </AkTypography>

      {{#if @isOverridden}}
        <AkTypography
          local-class='textarea-input reason-readonly'
          data-test-store-release-readiness-policy-details-override-reason-value
        >
          {{@overrideComment}}
        </AkTypography>
      {{else}}
        <Textarea
          id='store-release-readiness-policy-override-reason-field'
          data-test-store-release-readiness-policy-details-override-reason-input
          rows='6'
          placeholder={{t
            'storeReleaseReadiness.overrideIgnoreReasonPlaceholder'
          }}
          local-class='textarea-input'
          @value={{this.commentInput}}
          {{on 'input' this.onCommentInput}}
        />
      {{/if}}
    </AkStack>
  </div>

  {{#unless @isOverridden}}
    <AkDivider @color='dark' />

    <AkStack class='px-3 py-2' @alignItems='center' @spacing='2'>
      <AkButton
        data-test-store-release-readiness-policy-details-override-reason-save-button
        @disabled={{this.isSaveDisabled}}
        @loading={{this.saveOverrideComment.isRunning}}
        {{on 'click' (perform this.saveOverrideComment)}}
      >
        {{t 'storeReleaseReadiness.yesIgnore'}}
      </AkButton>

      <AkButton
        data-test-store-release-readiness-policy-details-override-reason-cancel-button
        @variant='outlined'
        @color='neutral'
        {{on 'click' @onClose}}
      >
        {{t 'cancel'}}
      </AkButton>
    </AkStack>
  {{/unless}}
</div>