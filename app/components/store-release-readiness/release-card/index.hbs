<div
  local-class='release-card'
  data-test-store-release-readiness-card
  data-test-store-release-readiness-card-id={{@item.id}}
>
  <AkStack @direction='column' @spacing='0' @width='full'>
    <AkStack
      @direction='row'
      @justifyContent='space-between'
      @alignItems='center'
      @width='full'
      local-class='card-header'
    >
      <AkChip
        @variant='semi-filled'
        @color='default'
        @size='small'
        @label={{@item.verdictDisplay}}
        local-class='{{this.riskChipClass}}'
        data-test-store-release-readiness-risk-chip
      >
        <:icon>
          {{#if this.riskChipSvgComponentName}}
            {{#let (component this.riskChipSvgComponentName) as |RiskChipSvg|}}
              <RiskChipSvg data-test-store-release-readiness-risk-chip-icon />
            {{/let}}
          {{else}}
            <AkIcon
              @iconName='content-paste-search'
              @size='small'
              data-test-store-release-readiness-risk-chip-icon
            />
          {{/if}}
        </:icon>
      </AkChip>

      <AkStack
        @direction='row'
        @alignItems='center'
        @spacing='0.5'
        data-test-store-release-readiness-header-status
      >
        {{#if this.isHeaderInProgress}}
          <AkLoader
            @size={{16}}
            @color='error'
            data-test-store-release-readiness-header-loader
          />
        {{else}}
          <AkIcon
            @iconName={{this.headerStatusMeta.iconName}}
            @color={{this.headerStatusMeta.iconColor}}
            @size='small'
          />
        {{/if}}

        <AkTypography @variant='body2'>
          {{this.headerStatusMeta.label}}
        </AkTypography>
      </AkStack>
    </AkStack>

    <AkStack
      @direction='column'
      @alignItems='flex-start'
      @spacing='0'
      @width='full'
      local-class='card-body'
    >
      <AppLogo
        @src={{@item.iconUrl}}
        @alt={{@item.fileName}}
        @size='medium'
        @rounded={{true}}
        data-test-store-release-readiness-app-logo
      />

      <AkStack
        @direction='column'
        @spacing='0'
        @width='full'
        local-class='app-name-block'
        data-test-store-release-readiness-app-name
      >
        <AkTypography
          @variant='subtitle1'
          @fontWeight='medium'
          local-class='app-name'
        >
          {{@item.fileName}}
        </AkTypography>
      </AkStack>

      <AkStack
        @direction='row'
        @justifyContent='space-between'
        @alignItems='center'
        @width='full'
        local-class='package-date-row'
        data-test-store-release-readiness-package-date-row
      >
        <div local-class='package-name-wrap'>
          <AkTypography
            @variant='body2'
            @color='textSecondary'
            local-class='package-name'
            data-test-store-release-readiness-package-name
          >
            {{@item.packageName}}
          </AkTypography>
        </div>

        <AkStack
          @direction='row'
          @alignItems='center'
          @spacing='0.5'
          data-test-store-release-readiness-package-date-meta
        >
          <div
            local-class='meta-data meta-data-icon'
            data-test-store-release-readiness-platform-box
          >
            <AppPlatformIcon
              data-test-store-release-readiness-platform-icon
              @platform={{@item.platformIcon}}
              @size='small'
            />
          </div>

          <div
            local-class='meta-data'
            data-test-store-release-readiness-release-date
          >
            <AkStack @direction='row' @alignItems='center' @spacing='0.5'>
              <AkIcon
                @iconName='event'
                @size='small'
                local-class='meta-data-date-icon'
              />
              <AkTypography @variant='body2' local-class='meta-data-date-text'>
                {{@item.releaseDateLabel}}
              </AkTypography>
            </AkStack>
          </div>
        </AkStack>
      </AkStack>

      <AkDivider
        @color='dark'
        local-class='summary-divider'
        data-test-store-release-readiness-summary-divider
      />

      <AkTypography
        @fontWeight='medium'
        local-class='summary-heading'
        data-test-store-release-readiness-summary-heading
      >
        {{t 'storeReleaseReadiness.summarySectionHeading'}}
      </AkTypography>

      <div local-class='summary-progress-wrap'>
        <StoreReleaseReadiness::ReleaseCard::SummaryProgressBar
          @failed={{@item.failedCount}}
          @passed={{@item.passedCount}}
          @untested={{@item.untestedCount}}
          @isLoading={{@item.summaryLoading}}
        />
      </div>

      <StoreReleaseReadiness::ReleaseCard::SummaryStatusList
        @failed={{@item.failedCount}}
        @blocker={{@item.blockerCount}}
        @warning={{@item.warningCount}}
        @passed={{@item.passedCount}}
        @untested={{@item.untestedCount}}
        @overridden={{@item.summaryOverridden}}
        @passedValueLoading={{@item.summaryPassedRowLoading}}
        @untestedValueLoading={{@item.summaryPassedRowLoading}}
      />
    </AkStack>
  </AkStack>
</div>