<div local-class='summary-root' class='mb-4'>
  <AkStack
    class='p-2'
    local-class='summary-header'
    @alignItems='center'
    @justifyContent='space-between'
  >
    <AkStack @alignItems='center' @spacing='1.5'>
      <AppLogo
        @src={{this.appLogoSrc}}
        @alt={{concat @scanData.displayName ' - logo'}}
      />

      <AkStack @direction='column' @spacing='0.5'>
        <AkTypography
          @variant='subtitle1'
          data-test-store-release-readiness-scan-summary-app-name
        >
          {{@scanData.displayName}}
        </AkTypography>

        <AkTypography
          @color='textSecondary'
          data-test-store-release-readiness-scan-summary-package-name
        >
          {{@scanData.packageNameValue}}
        </AkTypography>
      </AkStack>
    </AkStack>

    {{#if this.showReportButton}}
      <StoreReleaseReadiness::ScanResults::ReportDrawer
        @scanData={{@scanData}}
        @open={{this.openViewReportDrawer}}
        @onClose={{this.handleViewReportDrawerClose}}
      />

      <AkStack @alignItems='center' @spacing='1'>
        <AkButton
          {{style paddingRight='12px'}}
          {{on 'click' this.handleViewReportDrawerOpen}}
          data-test-store-release-readiness-scan-summary-view-report-button
        >
          <:leftIcon>
            <AkIcon @iconName='description-outline' />
          </:leftIcon>

          <:default>
            {{t 'viewReport'}}
          </:default>
        </AkButton>
      </AkStack>
    {{/if}}
  </AkStack>

  <AkDivider @color='dark' />

  <div class='px-2'>
    <AkStack
      @direction='row'
      @alignItems='center'
      @justifyContent='space-between'
      @width='full'
      local-class='summary-toolbar'
    >
      <AkStack
        local-class='summary-padding'
        @direction='row'
        @alignItems='center'
      >
        <AkStack @alignItems='center'>
          <AkIconButton
            @size='small'
            {{on 'click' this.handleFileSummaryToggle}}
            data-test-store-release-readiness-scan-summary-expand-button
          >
            <AkIcon
              @iconName={{if
                this.showMoreFileSummary
                'arrow-drop-up'
                'arrow-drop-down'
              }}
              local-class='show-more-icon'
            />
          </AkIconButton>

          <AkTypography @variant='subtitle1'>
            {{t 'fileID'}}
            -
          </AkTypography>

          <div local-class='summary-file-id'>
            <AkTypography
              @variant='subtitle1'
              data-test-store-release-readiness-scan-summary-release-id
            >
              {{this.fileId}}
            </AkTypography>
          </div>
        </AkStack>

        <AkDivider @direction='vertical' @height='26px' class='mx-1' />

        <AkStack @alignItems='center' @spacing='1'>
          <AkStack
            data-test-store-release-readiness-scan-summary-platform-box
            @justifyContent='center'
            @alignItems='center'
          >
            <AppPlatformIcon
              @platform={{@scanData.platformIcon}}
              @size='small'
            />
          </AkStack>
        </AkStack>
      </AkStack>

      <AkStack
        @direction='row'
        @alignItems='center'
        @spacing='0.5'
        data-test-store-release-readiness-scan-summary-analysis-status
      >
        {{#if @scanData.isInProgress}}
          <AkLoader
            @size={{16}}
            @color='error'
            data-test-store-release-readiness-scan-summary-status-loader
          />
        {{else}}
          <AkIcon
            @iconName={{this.headerAnalysisStatusDisplay.iconName}}
            @color={{this.headerAnalysisStatusDisplay.iconColor}}
            @size='small'
            data-test-store-release-readiness-scan-summary-status-icon
          />
        {{/if}}
        <AkTypography @variant='body2'>
          {{this.headerAnalysisStatusDisplay.label}}
        </AkTypography>

      </AkStack>
    </AkStack>

    {{#if this.showMoreFileSummary}}
      <AkDivider />

      {{#each this.fileSummary as |fs|}}
        <AkStack
          local-class='summary-padding'
          data-test-store-release-readiness-scan-summary-detail-row
        >
          <AkTypography
            {{style width='160px'}}
            @color='textSecondary'
            data-test-store-release-readiness-scan-summary-detail-label
          >
            {{fs.label}}
          </AkTypography>

          <AkTypography
            @variant='h6'
            data-test-store-release-readiness-scan-summary-detail-value
          >
            {{fs.value}}
          </AkTypography>
        </AkStack>

        <AkDivider />
      {{/each}}
    {{/if}}
  </div>
</div>