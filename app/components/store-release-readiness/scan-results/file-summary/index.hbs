<div local-class='summary-root' class='mb-4'>
  <AkStack
    class='p-2'
    local-class='summary-header'
    @alignItems='center'
    @justifyContent='space-between'
  >
    {{#if this.loading}}
      <AkStack @alignItems='center' @spacing='1.5'>
        <AppLogo @loading={{true}} />

        <AkStack @direction='column' @spacing='0.5'>
          <AkSkeleton @width='180px' @height='16px' />

          <AkSkeleton @width='115px' @height='16px' />
        </AkStack>
      </AkStack>
    {{else}}
      <AkStack @alignItems='center' @spacing='1.5'>
        <AppLogo
          @src={{this.placeholderAppLogoSrc}}
          @alt={{concat @item.title ' - logo'}}
        />

        <AkStack @direction='column' @spacing='0.5'>
          <AkTypography
            @variant='subtitle1'
            data-test-store-release-readiness-scan-summary-app-name
          >
            {{@item.appName}}
          </AkTypography>

          <AkTypography
            @color='textSecondary'
            data-test-store-release-readiness-scan-summary-package-name
          >
            {{@item.packageName}}
          </AkTypography>
        </AkStack>
      </AkStack>
    {{/if}}
  </AkStack>

  <AkDivider @color='dark' />

  <div class='px-2'>
    <AkStack
      @direction='row'
      @alignItems='center'
      @justifyContent='space-between'
      @width='full'
      local-class='summary-toolbar'
    >
      <AkStack
        local-class='summary-padding'
        @direction='row'
        @alignItems='center'
      >
        <AkStack @alignItems='center'>
          {{#if this.loading}}
            <AkSkeleton @width='115px' @height='16px' class='my-2' />
          {{else}}
            <AkIconButton
              @size='small'
              {{on 'click' this.handleFileSummaryToggle}}
              data-test-store-release-readiness-scan-summary-expand-button
            >
              <AkIcon
                @iconName={{if
                  this.showMoreFileSummary
                  'arrow-drop-up'
                  'arrow-drop-down'
                }}
                local-class='show-more-icon'
              />
            </AkIconButton>

            <AkTypography @variant='subtitle1'>
              {{t 'fileID'}}
              -
            </AkTypography>

            <div local-class='summary-file-id'>
              <AkTypography
                @variant='subtitle1'
                data-test-store-release-readiness-scan-summary-release-id
              >
                {{@item.id}}
              </AkTypography>
            </div>
          {{/if}}
        </AkStack>

        <AkDivider @direction='vertical' @height='26px' class='mx-1' />

        <AkStack @alignItems='center' @spacing='1'>
          {{#if this.loading}}
            <AkSkeleton @width='25px' @height='16px' />
          {{else}}
            <AkStack
              data-test-store-release-readiness-scan-summary-platform-box
              @justifyContent='center'
              @alignItems='center'
            >
              <AppPlatformIcon @platform={{@item.platform}} @size='small' />
            </AkStack>
          {{/if}}
        </AkStack>
      </AkStack>

      <AkStack
        @direction='row'
        @alignItems='center'
        @spacing='0.5'
        data-test-store-release-readiness-scan-summary-analysis-status
      >
        {{#if this.loading}}
          <AkSkeleton @width='100px' @height='16px' />
        {{else}}
          {{#if this.isHeaderInProgress}}
            <AkLoader
              @size={{16}}
              @color='error'
              data-test-store-release-readiness-scan-summary-status-loader
            />
          {{else}}
            <AkIcon
              @iconName={{this.headerStatusIconName}}
              @color={{this.headerStatusIconColor}}
              @size='small'
              data-test-store-release-readiness-scan-summary-status-icon
            />
          {{/if}}
          <AkTypography @variant='body2'>
            {{this.headerStatusLabel}}
          </AkTypography>
        {{/if}}
      </AkStack>
    </AkStack>

    {{#if this.showMoreFileSummary}}
      <AkDivider />

      {{#each this.fileSummary as |fs|}}
        <AkStack
          local-class='summary-padding'
          data-test-store-release-readiness-scan-summary-detail-row
        >
          <AkTypography
            {{style width='160px'}}
            @color='textSecondary'
            data-test-store-release-readiness-scan-summary-detail-label
          >
            {{fs.label}}
          </AkTypography>

          <AkTypography
            @variant='h6'
            data-test-store-release-readiness-scan-summary-detail-value
          >
            {{fs.value}}
          </AkTypography>
        </AkStack>

        <AkDivider />
      {{/each}}
    {{/if}}
  </div>
</div>