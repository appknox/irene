<AkStack @direction='column' @width='full' class='px-1'>
  <AkStack @width='full' @alignItems='center' @spacing='0.5'>
    <AkTypography
      @fontWeight='medium'
      @tag='span'
      @color='textSecondary'
      class='ml-1'
      {{style fontSize='0.857rem' marginBottom='0.5em !important'}}
    >
      {{@group.groupName}}

    </AkTypography>

    {{#if this.isProjectProfileFilters}}
      <AkLink
        @route='authenticated.dashboard.project.settings'
        @model={{this.fileProjectId}}
        target='_blank'
        rel='noopener noreferrer'
      >
        <AkIcon
          id='open-prj-settings-icon'
          @size='small'
          @color='primary'
          @iconName='open-in-new'
        />
      </AkLink>
    {{/if}}
  </AkStack>

  <AkStack @direction='column' @width='full'>
    {{#each @group.options as |option|}}
      <AkStack @width='full' @alignItems='center'>
        <AkCheckbox
          @checked={{this.isDomainFilterSelected option}}
          @onClick={{fn this.onSelectAPIUrlDomainChange option}}
        />

        <AkTypography @noWrap={{true}}>
          {{option}}
        </AkTypography>
      </AkStack>

    {{else}}
      <AkTypography
        @color='textSecondary'
        @variant='body2'
        @noWrap={{true}}
        class='mx-2'
        {{style fontStyle='italic'}}
      >
        No project domain filters available.
      </AkTypography>
    {{/each}}
  </AkStack>
</AkStack>

<AkDivider class='my-1' />