<PageWrapper local-class='navigation-graph-root' ...attributes>
  <AkBreadcrumbs::AutoTrail
    data-test-fileDetails-dynamicScan-navigationGraph-breadcrumbs
    local-class='breadcrumbs-container'
  />

  <div
    local-class='graph-canvas-wrapper'
    {{did-insert this.initializeGraph}}
    data-test-fileDetails-dynamicScan-navigationGraph-canvas
  ></div>

  <FileDetails::DynamicScan::NavigationGraph::NavPanel
    @variantCount={{this.variantCount}}
    @transitionCount={{this.transitionCount}}
    @layoutOptions={{this.layoutOptions}}
    @selectedLayoutOption={{this.selectedLayoutOption}}
    @onLayoutChange={{this.handleLayoutChange}}
  />

  {{#if this.selectedNode}}
    <AkDrawer
      data-test-fileDetails-dynamicScan-navigationGraph-drawer
      @open={{true}}
      @onClose={{this.closeNodeDetail}}
      @anchor='right'
      as |dr|
    >
      <div local-class='drawer-content'>
        <AkAppbar @justifyContent='space-between' as |ab|>
          <AkTypography
            data-test-fileDetails-dynamicScan-navigationGraph-drawerTitle
            @color='inherit'
            @variant='h5'
          >
            {{or this.selectedNode.title this.selectedNode.variant_id}}
          </AkTypography>

          <AkIconButton
            data-test-fileDetails-dynamicScan-navigationGraph-drawerClose
            class={{ab.classes.defaultIconBtn}}
            {{on 'click' dr.closeHandler}}
          >
            <AkIcon @iconName='close' />
          </AkIconButton>
        </AkAppbar>

        <AkStack
          @direction='column'
          @alignItems='center'
          @spacing='2'
          local-class='drawer-body'
        >
          <div local-class='screenshot-container'>
            {{#if this.selectedNode.screenshot_path}}
              {{#if this.imageLoading}}
                <div local-class='loading-container'>
                  <AkStack @alignItems='center' @spacing='2'>
                    <AkLoader @size={{16}} />
                    <AkTypography>{{t 'loading'}}...</AkTypography>
                  </AkStack>
                </div>
              {{/if}}

              <img
                local-class='
                  drawer-screenshot
                  {{if this.imageLoading "display-none"}}
                '
                src={{this.selectedNode.screenshot_path}}
                alt={{t
                  'navigationGraph.screenshotOf'
                  title=this.selectedNode.title
                }}
                {{on 'load' this.onScreenshotLoad}}
                data-test-fileDetails-dynamicScan-navigationGraph-drawerImage
              />
            {{else}}
              <div local-class='drawer-screenshot-placeholder'>
                <AkTypography @variant='body2' @color='textSecondary'>
                  {{t 'navigationGraph.noScreenshot'}}
                </AkTypography>
              </div>
            {{/if}}
          </div>

          <AkStack
            local-class='drawer-nav'
            @alignItems='center'
            @justifyContent='space-between'
          >
            <AkButton
              data-test-fileDetails-dynamicScan-navigationGraph-drawerPrev
              @variant='outlined'
              @color='neutral'
              @disabled={{not this.hasPreviousNode}}
              {{on 'click' this.showPreviousNode}}
            >
              <:leftIcon>
                <AkIcon @iconName='arrow-left' />
              </:leftIcon>

              <:default>{{t 'previous'}}</:default>
            </AkButton>

            <AkButton
              data-test-fileDetails-dynamicScan-navigationGraph-drawerNext
              @variant='outlined'
              @color='neutral'
              @disabled={{not this.hasNextNode}}
              {{on 'click' this.showNextNode}}
            >
              <:rightIcon>
                <AkIcon @iconName='arrow-right' />
              </:rightIcon>

              <:default>{{t 'next'}}</:default>
            </AkButton>
          </AkStack>
        </AkStack>
      </div>
    </AkDrawer>
  {{/if}}
</PageWrapper>