{{#if @showBreadcrumbs}}
  <AkBreadcrumbs::AutoTrail
    data-test-fileDetails-dynamicScan-navigationGraph-notFound-breadcrumbs
    local-class='breadcrumbs-container'
  />
{{/if}}

<AkStack
  @direction='column'
  @alignItems='center'
  @justifyContent='center'
  @spacing='4'
  local-class='not-found-root'
  data-test-fileDetails-dynamicScan-navigationGraph-notFound
  ...attributes
>
  <AkSvg::NoDataFound
    data-test-fileDetails-dynamicScan-navigationGraph-notFoundIllustration
  />

  <AkStack @direction='column' @alignItems='center' @spacing='2'>
    <AkStack @direction='column' @alignItems='center' @spacing='1'>
      <AkTypography
        @variant='h6'
        @fontWeight='bold'
        data-test-fileDetails-dynamicScan-navigationGraph-notFoundTitle
      >
        {{@title}}
      </AkTypography>

      <AkTypography
        @variant='body2'
        @color='textSecondary'
        @align='center'
        {{style maxWidth='480px'}}
        data-test-fileDetails-dynamicScan-navigationGraph-notFoundDescription
      >
        {{@description}}
      </AkTypography>
    </AkStack>

    <AkLink
      @route={{@buttonRoute}}
      @model={{@buttonModel}}
      data-test-fileDetails-dynamicScan-navigationGraph-notFoundActionLink
    >
      <AkButton
        data-test-fileDetails-dynamicScan-navigationGraph-notFoundActionBtn
      >
        {{@buttonText}}
      </AkButton>
    </AkLink>
  </AkStack>
</AkStack>