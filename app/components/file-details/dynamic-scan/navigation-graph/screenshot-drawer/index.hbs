<AkDrawer
  data-test-fileDetails-dynamicScan-navigationGraph-drawer
  @open={{true}}
  @onClose={{@onClose}}
  @anchor='right'
  as |dr|
>
  <div
    local-class='drawer-content'
    {{did-insert @onContentInsert}}
    {{will-destroy @onContentDestroy}}
  >
    <AkAppbar @justifyContent='space-between' as |ab|>
      <AkTypography
        data-test-fileDetails-dynamicScan-navigationGraph-drawerTitle
        @color='inherit'
        @variant='h5'
      >
        {{or @node.title @node.variant_id}}
      </AkTypography>

      <AkIconButton
        data-test-fileDetails-dynamicScan-navigationGraph-drawerClose
        class={{ab.classes.defaultIconBtn}}
        {{on 'click' dr.closeHandler}}
      >
        <AkIcon @iconName='close' />
      </AkIconButton>
    </AkAppbar>

    <AkStack
      @direction='column'
      @alignItems='center'
      @spacing='2'
      local-class='drawer-body'
    >
      <div local-class='screenshot-container'>
        {{#if @node.screenshot_path}}
          {{#if this.imageFailed}}
            <AkStack
              @alignItems='center'
              @justifyContent='center'
              local-class='screenshot-fallback'
              data-test-fileDetails-dynamicScan-navigationGraph-drawerImageFallback
            >
              <AkIcon
                @iconName='hugeicons:image-03'
                @color='textSecondary'
                {{style fontSize='2.5rem !important'}}
              />
            </AkStack>
          {{else}}
            {{#if this.imageLoading}}
              <div local-class='loading-container'>
                <AkStack @alignItems='center' @spacing='2'>
                  <AkLoader @size={{16}} />

                  <AkTypography>{{t 'loading'}}...</AkTypography>
                </AkStack>
              </div>
            {{/if}}

            <img
              local-class='
                drawer-screenshot
                {{if this.imageLoading "display-none"}}
              '
              src={{@node.screenshot_path}}
              alt={{t 'navigationGraph.screenshotOf' title=@node.title}}
              {{on 'load' this.onScreenshotLoad}}
              {{on 'error' this.onScreenshotError}}
              data-test-fileDetails-dynamicScan-navigationGraph-drawerImage
            />
          {{/if}}
        {{else}}
          <div local-class='drawer-screenshot-placeholder'>
            <AkTypography @variant='body2' @color='textSecondary'>
              {{t 'navigationGraph.noScreenshot'}}
            </AkTypography>
          </div>
        {{/if}}
      </div>

      <AkStack
        local-class='drawer-nav'
        @alignItems='center'
        @justifyContent='space-between'
      >
        <AkButton
          @variant='outlined'
          @color='neutral'
          @disabled={{not @hasPreviousNode}}
          {{on 'click' @onPrevious}}
          data-test-fileDetails-dynamicScan-navigationGraph-drawerPrev
        >
          <:leftIcon>
            <AkIcon @iconName='arrow-left' />
          </:leftIcon>

          <:default>{{t 'previous'}}</:default>
        </AkButton>

        <AkButton
          @variant='outlined'
          @color='neutral'
          @disabled={{not @hasNextNode}}
          {{on 'click' @onNext}}
          data-test-fileDetails-dynamicScan-navigationGraph-drawerNext
        >
          <:rightIcon>
            <AkIcon @iconName='arrow-right' />
          </:rightIcon>

          <:default>{{t 'next'}}</:default>
        </AkButton>
      </AkStack>
    </AkStack>
  </div>
</AkDrawer>