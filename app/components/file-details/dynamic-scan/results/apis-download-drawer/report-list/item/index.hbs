<AkList::Item
  data-test-fileDetails-apiScan-capturedApis-downloadDrawer-reportList-item
  class='px-3'
  @divider={{true}}
  as |li|
>
  {{#if (or this.isReportGenerated this.isReportGenerating)}}
    <li.leftIcon>
      {{#let (component @reportDetails.iconComponent) as |Icon|}}
        <Icon
          data-test-fileDetails-apiScan-capturedApis-downloadDrawer-reportList-item-icon
        />
      {{/let}}
    </li.leftIcon>

    <AkStack @direction='column' @width='full' @spacing='0.5' class='pl-1'>
      <AkTypography
        data-test-fileDetails-apiScan-capturedApis-downloadDrawer-reportList-item-primaryText
        @variant='subtitle1'
      >
        {{@reportDetails.primaryText}}
      </AkTypography>

      {{#if this.isReportGenerating}}
        <AkTypography
          data-test-fileDetails-apiScan-capturedApis-downloadDrawer-reportList-item-generatingText
          @color='textSecondary'
        >
          {{t 'generating'}}...
        </AkTypography>
      {{else}}
        <AkStack @alignItems='center' @spacing='0.5'>
          <AkTypography
            data-test-fileDetails-apiScan-capturedApis-downloadDrawer-reportList-item-secondaryText
          >
            {{@reportDetails.secondaryText}}
          </AkTypography>

          {{#if @reportDetails.copyText}}
            <AkClipboard
              @onSuccess={{this.handleCopySuccess}}
              @onError={{this.handleCopyError}}
              as |cb|
            >
              <AkIconButton
                id={{cb.triggerId}}
                @size='small'
                data-clipboard-text={{@reportDetails.copyText}}
                data-test-fileDetails-apiScan-capturedApis-downloadDrawer-reportList-item-copyBtn
              >
                <AkIcon
                  @iconName='content-copy'
                  @variant='outlined'
                  @color='primary'
                />
              </AkIconButton>
            </AkClipboard>
          {{/if}}
        </AkStack>
      {{/if}}

      <AkTypography
        @color='textSecondary'
        data-test-fileDetails-apiScan-capturedApis-downloadDrawer-reportList-item-generatedDate
      >
        {{@reportDetails.generatedDate}}
      </AkTypography>
    </AkStack>

    <li.rightIcon>
      {{#if this.isReportGenerating}}
        <AkLoader
          data-test-fileDetails-apiScan-capturedApis-downloadDrawer-reportList-item-generatingLoader
          @size={{18}}
        />
      {{else}}
        <AkIconButton
          {{on 'click' (perform this.handleDownloadReport @reportDetails.type)}}
          disabled={{this.handleDownloadReport.isRunning}}
          data-test-fileDetails-apiScan-capturedApis-downloadDrawer-reportList-item-downloadBtn
        >
          <AkIcon @iconName='download' />
        </AkIconButton>
      {{/if}}
    </li.rightIcon>
  {{else}}
    <AkStack @direction='column' @spacing='2' @width='full'>
      <AkTypography
        data-test-fileDetails-apiScan-capturedApis-downloadDrawer-reportList-item-generateTitle
        @variant='subtitle1'
      >
        {{t 'sbomModule.sbomDownloadPdfPrimaryText'}}
      </AkTypography>

      <AkStack
        local-class='generate-container'
        @direction='column'
        @spacing='2'
      >
        <AkSvg::GenerateReport
          data-test-fileDetails-apiScan-capturedApis-downloadDrawer-reportList-item-generateSvg
        />

        <AkTypography
          data-test-fileDetails-apiScan-capturedApis-downloadDrawer-reportList-item-generateDescription
        >
          {{t 'sbomModule.generateReportDescription'}}
        </AkTypography>

        <AkButton
          {{on 'click' (perform this.handleGenerateReport @reportDetails.type)}}
          @loading={{this.handleGenerateReport.isRunning}}
          data-test-fileDetails-apiScan-capturedApis-downloadDrawer-reportList-item-generateBtn
        >
          {{t 'generateReport'}}
        </AkButton>
      </AkStack>
    </AkStack>
  {{/if}}
</AkList::Item>