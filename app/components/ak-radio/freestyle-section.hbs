<FreestyleSection @name='Radio'>
  <FreestyleUsage @slug='ak-radio-basic' @title='Basic'>
    <AkRadio::Group @groupDirection='row' as |ctx|>
      <AkFormControlLabel @disabled={{false}} @label='Radio 1' as |fcl|>
        <AkRadio @value='radio1' @radioCtx={{ctx}} @disabled={{fcl.disabled}} />
      </AkFormControlLabel>
      <AkFormControlLabel @disabled={{false}} @label='Radio 2' as |fcl|>
        <AkRadio @value='radio2' @radioCtx={{ctx}} @disabled={{fcl.disabled}} />
      </AkFormControlLabel>
    </AkRadio::Group>
  </FreestyleUsage>
</FreestyleSection>
