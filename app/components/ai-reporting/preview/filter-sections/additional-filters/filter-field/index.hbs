<AkSelect
  @selected={{this.operator}}
  @options={{@operators}}
  @onChange={{this.handleOperatorChange}}
  @dropdownClass={{this.filterFieldDropdownClass}}
  @extra={{hash selectedItemLabel=(this.getFilterOperatorLabel this.operator)}}
  @selectedItemComponent={{component
    'ai-reporting/preview/filter-sections/additional-filters/truncated-filter-label'
  }}
  {{style maxWidth='120px'}}
  class='{{@field.field}}-filter-group-item-field-filter-operator-select'
  data-test-aiReporting-preview-filterByColumnDrawer-filterGroupContent-field-filterOperatorSelect
  as |opt|
>
  {{this.getFilterOperatorLabel opt}}
</AkSelect>

{{#unless this.hideValueComponent}}
  <div local-class='filter-field-container'>
    {{#let
      (component (ai-report-adv-filter-val-comp @field))
      as |ValueComponent|
    }}
      <ValueComponent
        @field={{@field}}
        @operator={{this.operator}}
        @currentValue={{this.currentValue}}
        @onAddUpdateFilter={{this.handleAddUpdateFilter}}
        @isErrored={{this.fieldError}}
      />
    {{/let}}
  </div>
{{/unless}}