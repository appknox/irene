<AkStack @direction='column' @spacing='1' local-class='ai-powered-feature-body'>
  <PoweredByAi::Chip @clickable={{true}} @drawerInfo={{this.drawerInfo}} />

  <AkStack @justifyContent='space-between' @width='full' @alignItems='center'>
    <AkTypography @fontWeight='medium'>
      {{t 'reportModule.settingsHeader'}}
    </AkTypography>

    <AkTooltip
      @arrow={{true}}
      @placement='bottom'
      @disabled={{this.showReporting}}
    >
      <:tooltipContent>
        {{t 'reportModule.settingsNoAccess'}}
      </:tooltipContent>

      <:default>
        <AkToggle
          @size='small'
          @checked={{this.aiFeatures.reporting}}
          @onChange={{this.toggle}}
          @disabled={{(not this.showReporting)}}
        />
      </:default>
    </AkTooltip>
  </AkStack>

  <AkTypography @variant='body2' @color='textSecondary' class='w-8/12'>
    {{t 'reportModule.settingsDesc'}}
  </AkTypography>
</AkStack>

<PoweredByAi::Drawer
  @aiDrawerOpen={{this.aiDrawerOpen}}
  @onClose={{this.closeAiDrawer}}
  @info={{this.drawerInfo}}
  @showButtons={{true}}
  @buttonText={{this.drawerButtonLabel}}
  @onButtonClick={{this.confirm}}
/>