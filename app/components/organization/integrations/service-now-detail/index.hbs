<div local-class='root'>
  <AkStack
    @alignItems='center'
    @justifyContent='space-between'
    class='py-2 px-3'
    local-class='page-header'
  >
    <AkStack @alignItems='center' @spacing='1.5'>
      {{#unless this.showRevokeConfirmBox}}
        <AkIconButton
          {{on 'click' this.handleBack}}
          data-test-orgIntegrations-serviceNowDetail-backBtn
        >
          <AkIcon @iconName='arrow-back' />
        </AkIconButton>
      {{/unless}}

      <img local-class='logo' src='/images/service-now.png' alt='ServiceNow' />

      <AkTypography @variant='subtitle1'>
        {{t 'serviceNow.newTitle'}}
      </AkTypography>
    </AkStack>

    {{#unless this.isServiceNowIntegrated}}
      {{#unless this.showRevokeConfirmBox}}
        <div local-class='step-chip'>
          <AkTypography @variant='subtitle1' @fontWeight='bold'>
            {{#if this.isStep2}}
              {{t 'configureStep2'}}
            {{else}}
              {{t 'configureStep1'}}
            {{/if}}
          </AkTypography>
        </div>
      {{/unless}}
    {{/unless}}
  </AkStack>

  <div local-class='content'>
    {{#if this.isLoadingData}}
      <AkStack @justifyContent='center' @alignItems='center' class='p-5'>
        <AkLoader @size={{32}} />
      </AkStack>

    {{else if this.showRevokeConfirmBox}}
      <div class='py-3 px-4'>
        <AkTypography @variant='body1'>
          {{t 'confirmBox.revokeServiceNow'}}
        </AkTypography>
      </div>

    {{else if this.isServiceNowIntegrated}}
      <Organization::Integrations::ServiceNowDetail::Integrated
        @instanceURL={{this.snInstanceURL}}
        @username={{this.snUsername}}
        @tableName={{this.resolvedTableName}}
        @autoPush={{this.snAutoPush}}
      />

    {{else if this.isStep2}}
      <Organization::Integrations::ServiceNowDetail::Step2
        @snTableItems={{this.snTableItems}}
        @selectedSNTable={{this.selectedSNTable}}
        @onSetSNTable={{this.setSNTable}}
        @isCustomTable={{this.isCustomTable}}
        @selectedCustomTable={{this.selectedCustomTable}}
        @customTableSuggestions={{this.customTableSuggestions}}
        @customTableSearch={{this.customTableSearch}}
        @onCustomTableSearch={{this.handleCustomTableSearch}}
        @onCustomTableSelect={{this.handleCustomTableSelect}}
        @onClearCustomTable={{this.clearCustomTable}}
        @filterAlwaysTrue={{this.filterAlwaysTrue}}
        @getCustomTableLabel={{this.getCustomTableLabel}}
        @searchCustomTablesIsRunning={{this.searchCustomTables.isRunning}}
        @fetchTableColumnsIsRunning={{this.fetchTableColumns.isRunning}}
        @appknoxSourceKeyOptions={{this.appknoxSourceKeyOptions}}
        @availableColumnsFor={{this.availableColumnsFor}}
        @fieldMapping={{this.fieldMapping}}
        @onUpdateMapping={{this.updateMapping}}
      />

    {{else}}
      <Organization::Integrations::ServiceNowDetail::Step1
        @changeset={{this.changeset}}
        @autoPush={{this.autoPush}}
        @onToggleAutoPush={{this.toggleAutoPush}}
      />
    {{/if}}
  </div>

  {{#unless this.isLoadingData}}
    <div local-class='footer'>
      {{#if this.showRevokeConfirmBox}}
        <AkButton
          @variant='filled'
          @loading={{this.revokeIntegration.isRunning}}
          @disabled={{this.revokeIntegration.isRunning}}
          {{on 'click' (perform this.revokeIntegration)}}
          data-test-orgIntegrations-serviceNowDetail-disconnectBtnConfirmation
        >
          {{t 'yesDisconnect'}}
        </AkButton>

        <AkButton
          @variant='outlined'
          @color='neutral'
          @disabled={{this.revokeIntegration.isRunning}}
          {{on 'click' this.closeRevokeConfirmBox}}
          data-test-orgIntegrations-serviceNowDetail-cancelBtnConfirmation
        >
          {{t 'cancel'}}
        </AkButton>
      {{else if this.isServiceNowIntegrated}}
        <AkButton
          @variant='outlined'
          @color='neutral'
          {{on 'click' this.openRevokeConfirmBox}}
          data-test-orgIntegrations-serviceNowDetail-disconnectBtn
        >
          {{t 'disconnect'}}
        </AkButton>

      {{else if this.isStep2}}
        <AkButton
          @variant='filled'
          @loading={{this.completeIntegration.isRunning}}
          @disabled={{not this.canIntegrate}}
          {{on 'click' (perform this.completeIntegration)}}
          data-test-orgIntegrations-serviceNowDetail-integrateBtn
        >
          {{t 'integrate'}}
        </AkButton>
      {{else}}
        <AkButton
          @variant='filled'
          @loading={{this.goToStep2.isRunning}}
          @disabled={{this.goToStep2.isRunning}}
          {{on 'click' (perform this.goToStep2 this.changeset)}}
          data-test-orgIntegrations-serviceNowDetail-proceedBtn
        >
          {{t 'saveAndProceed'}}
        </AkButton>
      {{/if}}
    </div>
  {{/unless}}
</div>