<AkBreadcrumbs::AutoTrail
  data-test-storeknoxFakeAppsFakeAppDetails-breadcrumbContainer
/>

<Storeknox::FakeApps::FakeAppDetails::Header
  @skInventoryApp={{@skInventoryApp}}
/>

<AkTabs as |Akt|>
  {{#each this.tabItems as |item|}}
    <Akt.tabItem
      @id={{item.id}}
      @hasBadge={{true}}
      @badgeCount={{item.count}}
      @route={{item.route}}
      @model={{@skInventoryApp.id}}
      @indicatorVariant='shadow'
      data-test-storeknoxFakeAppsFakeAppDetails-fakeApp-tab='{{item.id}}'
    >
      {{item.label}}
    </Akt.tabItem>
  {{/each}}
</AkTabs>