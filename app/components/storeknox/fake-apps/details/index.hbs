<Storeknox::FakeApps::DetailsHeader
  @fakeApp={{@fakeApp}}
  @isFakeAppIgnored={{this.isFakeAppIgnored}}
/>

<AkStack @width='full' @spacing='2' @alignItems='stretch'>
  <AkStack
    @direction='column'
    class='{{if this.isFakeAppIgnored "is-ignored"}}'
    {{style width='70%'}}
    data-test-storeknoxFakeAppsDetails-findingsContainer
  >
    <Storeknox::FakeApps::FindingsCard
      @isDefaultFinding={{true}}
      @description={{this.overallFindingData.description}}
      @score={{this.overallFindingData.score}}
      @title={{this.overallFindingData.title}}
      @isIgnored={{this.overallFindingData.isIgnored}}
    />

    <Storeknox::FakeApps::FindingsGroup
      @groupData={{this.brandIdentityGroup}}
      @isIgnored={{this.isFakeAppIgnored}}
      @onSignalClick={{this.openDrawer}}
    />

    {{#if this.binarySimilarityGroup}}
      <Storeknox::FakeApps::FindingsGroup
        @groupData={{this.binarySimilarityGroup}}
        @isIgnored={{this.isFakeAppIgnored}}
        @onSignalClick={{this.openDrawer}}
      />
    {{/if}}

    {{#if this.securityRiskGroup}}
      <Storeknox::FakeApps::FindingsGroup
        @groupData={{this.securityRiskGroup}}
        @isIgnored={{this.isFakeAppIgnored}}
        @onSignalClick={{this.openDrawer}}
      />
    {{/if}}
  </AkStack>

  <Storeknox::FakeApps::OriginalAppInfo
    @isIgnored={{this.isFakeAppIgnored}}
    @skInventoryApp={{@skInventoryApp}}
  />
</AkStack>

<Storeknox::FakeApps::SignalDetailDrawer
  @isOpen={{if this.selectedSignal true false}}
  @sectionTitle={{this.drawerSectionTitle}}
  @signal={{this.selectedSignal}}
  @onClose={{this.closeDrawer}}
/>