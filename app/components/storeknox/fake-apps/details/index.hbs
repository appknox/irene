<Storeknox::FakeApps::DetailsHeader
  @fakeApp={{@fakeApp}}
  @isFakeAppIgnored={{this.isFakeAppIgnored}}
/>

<AkStack @width='full' @spacing='2' @alignItems='stretch'>
  <AkStack
    @bgColor='white'
    @direction='column'
    local-class='findings-card-container {{if
      this.isFakeAppIgnored
      "is-ignored"
    }}'
    {{style width='70%'}}
  >
    {{#each this.fakeAppFindingsCategoryData as |item index|}}
      {{#if (not (or item.isDefaultFinding (eq index 1)))}}
        <AkDivider @color='dark' local-class='findings-card-divider' />
      {{/if}}

      <Storeknox::FakeApps::FindingsCard
        @isDefaultFinding={{item.isDefaultFinding}}
        @description={{item.description}}
        @score={{item.score}}
        @title={{item.title}}
        @isIgnored={{item.isIgnored}}
      />
    {{/each}}
  </AkStack>

  <Storeknox::FakeApps::OriginalAppInfo
    @isIgnored={{this.isFakeAppIgnored}}
    @skInventoryApp={{@skInventoryApp}}
  />
</AkStack>