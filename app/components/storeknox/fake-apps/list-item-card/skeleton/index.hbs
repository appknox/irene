<AkStack
  @bgColor='white'
  @width='full'
  @direction='column'
  local-class='fake-apps-item-card-root'
  ...attributes
>
  <AkStack
    @width='full'
    @direction='row'
    @alignItems='center'
    local-class='app-info-container'
  >
    <AkStack @width='full' @alignItems='center' @spacing='2'>
      {{! App Logo }}
      <AkSkeleton
        @width='58px'
        @height='58px'
        @variant='circular'
        local-class='app-info-logo'
      />

      <AkStack @spacing='0.75' @direction='column' @alignItems='flex-start'>
        {{! App Title }}
        <AkSkeleton @width='180px' @height='1.5rem' @variant='rounded' />

        {{! Package Name }}
        <AkSkeleton @width='200px' @height='1rem' @variant='rounded' />

        {{! Developer Name }}
        <AkSkeleton @width='150px' @height='1rem' @variant='rounded' />
      </AkStack>
    </AkStack>

    <AkStack
      @spacing='1'
      @alignItems='center'
      @justifyContent='center'
      local-class='store-logo-container'
      {{style alignSelf='flex-end' justifySelf='flex-end'}}
    >
      {{! Store Logo }}
      <AkSkeleton @width='16px' @height='16px' @variant='rounded' />
    </AkStack>
  </AkStack>

  <AkDivider @color='dark' local-class='divider' />

  <AkStack
    @direction='column'
    @alignItems='center'
    @justifyContent='center'
    @width='full'
    @spacing='1'
  >
    {{! Icon }}
    <AkSkeleton @width='34px' @height='34px' @variant='circular' />

    {{! Total Count }}
    <AkSkeleton @width='40px' @height='2rem' @variant='rounded' />

    {{! Label }}
    <AkSkeleton @width='120px' @height='1rem' @variant='rounded' />
  </AkStack>

  <AkStack
    @direction='column'
    @alignItems='center'
    @justifyContent='center'
    @width='full'
    {{style padding='0 1.7143em'}}
  >
    <AkDivider @color='dark' local-class='divider' />

    <AkStack
      @direction='column'
      @alignItems='center'
      @justifyContent='center'
      @width='full'
      @spacing='1'
    >
      <AkStack
        @direction='row'
        @alignItems='center'
        @justifyContent='space-between'
        @width='full'
      >
        {{! Brand Abuse Label }}
        <AkSkeleton @width='90px' @height='1rem' @variant='rounded' />

        {{! Brand Abuse Count }}
        <AkSkeleton @width='60px' @height='1rem' @variant='rounded' />
      </AkStack>

      {{! Brand Abuse Progress Bar }}
      <AkSkeleton @width='100%' @height='12px' @variant='rounded' />
    </AkStack>

    <AkStack
      @direction='column'
      @alignItems='center'
      @justifyContent='center'
      @width='full'
      @spacing='1'
      class='mt-3'
    >
      <AkStack
        @direction='row'
        @alignItems='center'
        @justifyContent='space-between'
        @width='full'
      >
        {{! Fake App Label }}
        <AkSkeleton @width='70px' @height='1rem' @variant='rounded' />

        {{! Fake App Count }}
        <AkSkeleton @width='60px' @height='1rem' @variant='rounded' />
      </AkStack>

      {{! Fake App Progress Bar }}
      <AkSkeleton @width='100%' @height='12px' @variant='rounded' />
    </AkStack>

    <AkDivider @color='dark' {{style marginTop='1.4286em'}} />

    <AkStack
      @direction='column'
      @alignItems='flex-start'
      @justifyContent='center'
      @width='full'
      local-class='last-monitoring-date-container'
    >
      {{! Last Monitoring Label }}
      <AkSkeleton @width='150px' @height='1rem' @variant='rounded' />

      {{! Last Monitoring Date }}
      <AkSkeleton
        @width='100px'
        @height='1rem'
        @variant='rounded'
        {{style marginTop='0.5rem'}}
      />
    </AkStack>
  </AkStack>
</AkStack>