<AkStack
  @bgColor='white'
  @width='full'
  @direction='column'
  local-class='fake-apps-item-card-root'
  {{on 'click' this.openFakeAppDetails}}
>
  <AkStack
    @width='full'
    @direction='row'
    @alignItems='center'
    local-class='app-info-container'
  >
    <AkStack @width='full' @alignItems='center' @spacing='2'>
      <img
        local-class='app-info-logo'
        src={{this.skApp.appMetadata.iconUrl}}
        alt={{this.skApp.title}}
        data-test-storeknoxFakeApps-itemCardAppLogoImage
      />

      <AkStack @spacing='0.75' @direction='column' @alignItems='flex-start'>
        <AkButton
          @tag='a'
          @variant='text'
          @color='textPrimary'
          @underline='always'
          href={{this.skApp.appMetadata.url}}
          target='_blank'
          rel='noopener noreferrer'
          {{style justifyContent='flex-start'}}
        >
          <AkTypography
            @variant='h5'
            @fontWeight='bold'
            {{style maxWidth='100%' textAlign='left'}}
            data-test-storeknoxInventoryDetails-headerAppTitle
          >
            {{this.skApp.appMetadata.title}}
          </AkTypography>
        </AkButton>

        <AkTypography
          @color='textPrimary'
          @noWrap={{true}}
          title={{this.skApp.appMetadata.packageName}}
          {{style maxWidth='240px'}}
          data-test-storeknoxInventoryDetails-headerAppPackageName
        >
          {{this.skApp.appMetadata.packageName}}
        </AkTypography>

        <AkTypography
          @color='textSecondary'
          @noWrap={{true}}
          {{style maxWidth='240px'}}
          title={{this.skApp.appMetadata.devName}}
          data-test-storeknoxFakeApps-itemCardAppDeveloperName
        >
          {{t 'by'}}
          {{this.skApp.appMetadata.devName}}
        </AkTypography>
      </AkStack>
    </AkStack>

    <AkStack
      @spacing='1'
      @alignItems='center'
      @justifyContent='center'
      local-class='store-logo-container'
      {{style alignSelf='flex-end' justifySelf='flex-end'}}
    >

      {{#if this.skApp.isAndroid}}
        <AkSvg::PlaystoreLogo
          {{style width='16px' height='16px'}}
          data-test-storeknoxFakeApps-itemCardPlayStoreLogo
        />

      {{else}}
        <AkSvg::AppstoreLogo
          {{style width='16px' height='16px'}}
          data-test-storeknoxFakeApps-itemCardAppStoreLogo
        />
      {{/if}}
    </AkStack>
  </AkStack>

  <AkDivider @color='dark' local-class='divider' />

  <AkStack
    @direction='column'
    @alignItems='center'
    @justifyContent='center'
    @width='full'
    @spacing='1'
  >
    <AkIcon
      @iconName='fluent:app-recent-24-regular'
      @color='primary'
      {{style fontSize='34px !important'}}
    />

    <AkTypography @variant='h2' @fontWeight='bold'>
      {{this.skApp.totalFakeApps}}
    </AkTypography>

    <AkTypography @color='textSecondary'>
      {{t 'storeknox.fakeApps.suspectedApps'}}
    </AkTypography>
  </AkStack>

  <AkStack
    @direction='column'
    @alignItems='center'
    @justifyContent='center'
    @width='full'
    {{style padding='0 1.7143em'}}
  >
    <AkDivider @color='dark' local-class='divider' />

    <AkStack
      @direction='column'
      @alignItems='center'
      @justifyContent='center'
      @width='full'
      @spacing='1'
    >
      <AkStack
        @direction='row'
        @alignItems='center'
        @justifyContent='space-between'
        @width='full'
      >
        <AkTypography>{{t 'storeknox.brandAbuse'}}</AkTypography>

        <AkTypography @tag='span' @fontWeight='bold'>
          {{this.skApp.fakeAppCounts.brand_abuse}}

          <AkTypography @tag='span' @color='textSecondary'>
            {{t 'outOf'}}
          </AkTypography>

          {{this.skApp.totalFakeApps}}
        </AkTypography>
      </AkStack>

      <AkLoader::Linear
        @height={{12}}
        @variant='determinate'
        @progress={{this.skApp.brandAbuseFakeAppPercentage}}
        local-class='brand-abuse-count-progress'
      />
    </AkStack>

    <AkStack
      @direction='column'
      @alignItems='center'
      @justifyContent='center'
      @width='full'
      @spacing='1'
      class='mt-3'
    >
      <AkStack
        @direction='row'
        @alignItems='center'
        @justifyContent='space-between'
        @width='full'
      >
        <AkTypography>{{t 'storeknox.fakeApps.fakeApp'}}</AkTypography>

        <AkTypography @tag='span' @fontWeight='bold'>
          {{this.skApp.fakeAppCounts.fake_app}}

          <AkTypography @tag='span' @color='textSecondary'>
            {{t 'outOf'}}
          </AkTypography>

          {{this.skApp.totalFakeApps}}
        </AkTypography>
      </AkStack>

      <AkLoader::Linear
        @height={{12}}
        @variant='determinate'
        @progress={{this.skApp.fakeAppsFakeAppPercentage}}
        local-class='fake-app-count-progress'
      />
    </AkStack>

    <AkDivider @color='dark' {{style marginTop='1.4286em'}} />

    <AkStack
      @direction='column'
      @alignItems='flex-start'
      @justifyContent='center'
      @width='full'
      local-class='last-monitoring-date-container'
    >
      <AkTypography @color='textSecondary' @gutterBottom={{true}}>
        {{t 'storeknox.lastMonitoringDate'}}
      </AkTypography>

      <AkTypography @fontWeight='bold'>
        {{this.lastMonitoringDate}}
      </AkTypography>
    </AkStack>
  </AkStack>
</AkStack>