{{#if @loading}}
  <AkSkeleton @width='160px' @height='16px' />
{{else}}
  <AkLink
    @route='authenticated.storeknox.fake-apps.fake-app-details'
    @models={{array @data.skInventoryApp.id @data.id}}
    data-test-storeknoxFakeAppListTable-appName
  >
    <AkTypography @fontWeight='medium' @color='secondary' @underline='always'>
      {{@data.appName}}
    </AkTypography>
  </AkLink>
{{/if}}