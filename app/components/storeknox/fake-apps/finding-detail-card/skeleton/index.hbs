<div local-class='finding-detail-card' ...attributes>
  {{! Card Header }}
  <AkStack @justifyContent='space-between' @alignItems='center' class='mb-2'>
    {{! PoweredByAi Chip }}
    <AkSkeleton @width='100px' @height='24px' @variant='rounded' />

    {{! Menu Button }}
    <AkSkeleton @width='24px' @height='24px' @variant='circular' />
  </AkStack>

  {{! Score Section }}
  <AkStack @alignItems='flex-start' class='mb-3'>
    <AkStack
      @direction='column'
      @alignItems='flex-start'
      @spacing='1'
      {{style minWidth='170px'}}
    >
      {{! Overall Score Label }}
      <AkStack @spacing='0.5' @alignItems='center'>
        <AkSkeleton @width='90px' @height='1rem' @variant='rounded' />
        <AkSkeleton @width='16px' @height='16px' @variant='circular' />
      </AkStack>

      {{! Overall Score Value }}
      <AkSkeleton @width='60px' @height='2rem' @variant='rounded' />
    </AkStack>

    <AkStack @alignItems='flex-start' @spacing='6'>
      {{! Score Items - repeat 4 times for semantic, package, logo, developer }}
      {{#each (array 1 2 3 4) as |index|}}
        <AkStack @direction='column' @spacing='1' id='skeleton-score-{{index}}'>
          {{! Score Label }}
          <AkSkeleton @width='70px' @height='0.875rem' @variant='rounded' />

          {{! Score Value }}
          <AkSkeleton @width='50px' @height='1.5rem' @variant='rounded' />
        </AkStack>
      {{/each}}
    </AkStack>
  </AkStack>

  <AkDivider @color='dark' />

  {{! App Detail Section }}
  <AkStack @direction='column' @spacing='2' class='mt-3'>
    {{! Logo Row }}
    <AkStack @alignItems='center'>
      <div local-class='detail-label'>
        <AkSkeleton @width='100px' @height='1rem' @variant='rounded' />
      </div>

      <AkSkeleton
        @width='24px'
        @height='24px'
        @variant='circular'
        local-class='app-logo'
      />
    </AkStack>

    {{! App Name Row }}
    <AkStack @alignItems='center'>
      <div local-class='detail-label'>
        <AkSkeleton @width='120px' @height='1rem' @variant='rounded' />
      </div>

      <AkSkeleton @width='150px' @height='1rem' @variant='rounded' />
    </AkStack>

    {{! Namespace Row }}
    <AkStack @alignItems='center'>
      <div local-class='detail-label'>
        <AkSkeleton @width='80px' @height='1rem' @variant='rounded' />
      </div>

      <AkSkeleton @width='200px' @height='1rem' @variant='rounded' />
    </AkStack>

    {{! Platform Row }}
    <AkStack @alignItems='center'>
      <div local-class='detail-label'>
        <AkSkeleton @width='110px' @height='1rem' @variant='rounded' />
      </div>

      <AkSkeleton @width='24px' @height='24px' @variant='rounded' />
    </AkStack>

    {{! Store Row }}
    <AkStack @alignItems='center'>
      <div local-class='detail-label'>
        <AkSkeleton @width='100px' @height='1rem' @variant='rounded' />
      </div>

      <AkSkeleton @width='16px' @height='16px' @variant='rounded' />
    </AkStack>

    {{! Developer Row with View More Button }}
    <AkStack
      @alignItems='center'
      @justifyContent='space-between'
      @spacing='3'
      @width='full'
    >
      <AkStack @alignItems='center'>
        <div local-class='detail-label'>
          <AkSkeleton @width='140px' @height='1rem' @variant='rounded' />
        </div>

        <AkSkeleton @width='120px' @height='1rem' @variant='rounded' />
      </AkStack>

      {{! View More Button }}
      <AkSkeleton @width='100px' @height='36px' @variant='rounded' />
    </AkStack>
  </AkStack>
</div>