<div
  local-class='finding-detail-card {{if @finding.isIgnored "ignored"}}'
  ...attributes
>
  {{! Card Header }}
  <AkStack @justifyContent='space-between' @alignItems='center' class='mb-2'>
    <PoweredByAi::Chip
      @clickable={{false}}
      @chipText={{t 'storeknox.fakeApps.findings'}}
      class='m-0'
      data-test-storeknoxFakeAppsFindingDetailCard-poweredByAiChip
    />

    {{#unless this.fakeAppIsIgnored}}
      <AkIconButton
        {{on 'click' this.handleOpenMenu}}
        data-test-storeknoxFakeAppsFindingDetailCard-menuBtn
      >
        <AkIcon @iconName='more-vert' />
      </AkIconButton>
    {{/unless}}
  </AkStack>

  {{! Score Section }}
  <AkStack @alignItems='flex-start' class='mb-3'>
    <AkStack
      @direction='column'
      @alignItems='flex-start'
      @spacing='1'
      {{style minWidth='170px'}}
    >
      <AkStack @spacing='0.5' @alignItems='center'>
        <AkTypography @color='primary' @variant='body2' @fontWeight='medium'>
          {{t 'storeknox.fakeApps.overallScore'}}
        </AkTypography>

        <AkTooltip
          @title={{t 'storeknox.fakeApps.overallScoreInfo' htmlSafe=true}}
          @arrow={{true}}
        >
          <AkIcon @iconName='info' @size='small' @color='textSecondary' />
        </AkTooltip>
      </AkStack>

      <AkTypography
        @variant='h3'
        @color='primary'
        @fontWeight='bold'
        data-test-storeknoxFakeAppsFindingDetailCard-overallScore
      >
        {{@finding.overallScore}}%
      </AkTypography>
    </AkStack>

    <AkStack @alignItems='flex-start' @spacing='6'>
      {{#each this.scoreItems as |item|}}
        <AkStack @direction='column' @spacing='1'>
          <AkTypography @color='textSecondary' @variant='body2'>
            {{item.label}}
          </AkTypography>

          <AkTypography
            @variant='h4'
            @fontWeight='regular'
            data-test-storeknoxFakeAppsFindingDetailCard-score='{{item.id}}'
          >
            {{item.value}}%
          </AkTypography>
        </AkStack>
      {{/each}}
    </AkStack>
  </AkStack>

  <AkDivider @color='dark' />

  {{! App Detail Section }}
  <AkStack @direction='column' @spacing='2' class='mt-3'>
    <AkStack @alignItems='center'>
      <AkTypography @color='textSecondary' local-class='detail-label'>
        {{t 'storeknox.fakeApps.logo'}}
      </AkTypography>

      {{#if @finding.appLogoUrl}}
        <img
          local-class='app-logo'
          src={{@finding.appLogoUrl}}
          alt={{@finding.appName}}
          data-test-storeknoxFakeAppsFindingDetailCard-appLogo
        />
      {{else}}
        <div local-class='app-logo-placeholder' />
      {{/if}}
    </AkStack>

    <AkStack @alignItems='center'>
      <AkTypography @color='textSecondary' local-class='detail-label'>
        {{t 'appName'}}
      </AkTypography>

      <AkTypography
        @fontWeight='bold'
        data-test-storeknoxFakeAppsFindingDetailCard-appName
      >
        {{@finding.appName}}
      </AkTypography>
    </AkStack>

    <AkStack @alignItems='center'>
      <AkTypography @color='textSecondary' local-class='detail-label'>
        {{t 'namespace'}}
      </AkTypography>

      <AkTypography data-test-storeknoxFakeAppsFindingDetailCard-namespace>
        {{@finding.namespace}}
      </AkTypography>
    </AkStack>

    <AkStack @alignItems='center'>
      <AkTypography @color='textSecondary' local-class='detail-label'>
        {{t 'platform'}}
      </AkTypography>

      <AppPlatformIcon
        @platform={{if @finding.isAndroid 'android' 'apple'}}
        data-test-storeknoxFakeAppsFindingDetailCard-platformIcon
      />
    </AkStack>

    <AkStack @alignItems='center'>
      <AkTypography @color='textSecondary' local-class='detail-label'>
        {{t 'storeknox.store'}}
      </AkTypography>

      {{#if @finding.isAndroid}}
        <AkSvg::PlaystoreLogo
          {{style width='16px'}}
          data-test-storeknoxFakeAppsFindingDetailCard-playstoreLogo
        />
      {{else}}
        <AkSvg::AppstoreLogo
          {{style width='16px'}}
          data-test-storeknoxFakeAppsFindingDetailCard-appstoreLogo
        />
      {{/if}}
    </AkStack>

    <AkStack
      @alignItems='center'
      @justifyContent='space-between'
      @spacing='3'
      @width='full'
    >
      <AkStack @alignItems='center'>
        <AkTypography @color='textSecondary' local-class='detail-label'>
          {{t 'storeknox.developer'}}
        </AkTypography>

        <AkTypography
          @fontWeight='bold'
          data-test-storeknoxFakeAppsFindingDetailCard-developer
        >
          {{@finding.developer}}
        </AkTypography>
      </AkStack>

      {{#if @finding.id}}
        <AkLink
          @route='authenticated.storeknox.fake-apps.fake-app-details'
          @models={{array @skInventoryApp.id @finding.id}}
        >
          <AkButton
            @variant='filled'
            data-test-storeknoxFakeAppsFindingDetailCard-viewMoreBtn
          >
            <:default>
              {{t 'viewMore'}}
            </:default>

            <:rightIcon>
              <AkIcon @iconName='chevron-right' />
            </:rightIcon>
          </AkButton>
        </AkLink>
      {{/if}}
    </AkStack>
  </AkStack>

  <AkMenu
    @anchorRef={{this.anchorRef}}
    @arrow={{true}}
    @onClose={{this.handleCloseMenu}}
    as |akm|
  >
    {{#each this.menuItems as |item|}}
      <akm.listItem @divider={{item.divider}} @onClick={{item.onClick}} as |li|>
        <li.text @primaryText={{item.label}} />
      </akm.listItem>
    {{/each}}
  </AkMenu>

  {{! Add ignore drawer }}
  <Storeknox::FakeApps::IgnoreDrawer
    @fakeApp={{@fakeApp}}
    @open={{this.showIgnoreDrawer}}
    @onClose={{this.closeIgnoreDrawer}}
    @addToInventory={{this.addToInventory}}
  />
</div>