<AkStack
  @alignItems='center'
  @justifyContent='space-between'
  @width='full'
  class='p-3'
  local-class='risk-section'
>
  <AkStack @direction='column' @spacing='0.5'>
    <AkTypography @fontWeight='medium'>
      {{t 'riskScore'}}
    </AkTypography>

    {{#if this.hasScore}}
      <AkTypography
        @variant='h1'
        @fontWeight='bold'
        local-class='risk-score'
        data-test-storeknoxThirdPartyScansAppDetailsRiskSection-score
      >
        {{@app.score}}<span local-class='risk-score-total'>/100</span>
      </AkTypography>

      <AkTypography
        @color='textSecondary'
        @variant='body2'
        data-test-storeknoxThirdPartyScansAppDetailsRiskSection-versionAnalysis
      >
        {{t
          'storeknox.basedOnVersionAnalysis'
          htmlSafe=true
          version=@app.version
        }}
      </AkTypography>

    {{else}}
      <AkTypography
        @variant='h3'
        @fontWeight='bold'
        data-test-storeknoxThirdPartyScansAppDetailsRiskSection-unavailable
      >
        {{t 'storeknox.riskScoreUnavailable'}}
      </AkTypography>
    {{/if}}
  </AkStack>

  {{#if this.riskSvgComponent}}
    {{#let (component this.riskSvgComponent) as |RiskSvg|}}
      <RiskSvg {{style width='100px'}} />
    {{/let}}
  {{/if}}
</AkStack>