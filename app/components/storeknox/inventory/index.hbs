<AkStack
  @direction='row'
  @alignItems='center'
  @justifyContent='space-between'
  local-class='header-storeknox-discover-page'
>
  <AkStack @direction='column' @spacing='0.5'>
    <AkTypography @variant='subtitle1'>
      {{t 'storeknox.inventoryHeader'}}
    </AkTypography>

    <AkStack @spacing='0.5' @direction='row' @alignItems='center'>
      <AkTypography @variant='body2' @color='neutral'>
        {{t 'storeknox.inventoryDescription'}}
      </AkTypography>

      <AkButton
        @variant='text'
        @underline='always'
        @typographyFontWeight='bold'
      >
        {{t 'viewMore'}}
      </AkButton>
    </AkStack>
  </AkStack>

  <AkStack @alignItems='center' @justifyContent='center' @spacing='1.5'>
    <AkButton>
      <AkLink
        @underline='none'
        @color='inherit'
        @route='authenticated.storeknox.discover.result'
      >
        {{t 'storeknox.discoverHeader'}}
      </AkLink>
    </AkButton>

    <AkDivider @variant='vertical' @color='dark' {{style height='32px'}} />

    <AkIconButton
      @size='medium'
      @variant='outlined'
      {{on 'click' this.openSettingsDrawer}}
    >
      <AkIcon @iconName='settings' />
    </AkIconButton>
  </AkStack>
</AkStack>

<AkTabs class='mb-3' as |Akt|>
  {{#each this.tabItems as |item|}}
    <Akt.tabItem
      @id={{item.id}}
      @badgeBackground={{true}}
      @route={{item.route}}
      @hasBadge={{item.hasBadge}}
      @badgeCount={{item.badgeCount}}
    >
      {{item.label}}
    </Akt.tabItem>
  {{/each}}
</AkTabs>

<AkDrawer
  @open={{this.showSettingsDrawer}}
  @onClose={{this.closeSettingsDrawer}}
  @anchor='right'
  as |dr|
>
  <AkStack @direction='column' {{style width='640px'}}>
    <AkAppbar
      @position='sticky'
      @justifyContent='space-between'
      class='px-3'
      as |ab|
    >
      <AkTypography
        @color='inherit'
        @variant='h5'
        @fontWeight='medium'
        data-test-addProjectTeam-drawerContainer-title
      >
        Inventory Settings
      </AkTypography>

      <AkIconButton
        {{on 'click' dr.closeHandler}}
        class={{ab.classes.defaultIconBtn}}
        data-test-addProjectTeam-drawerContainer-closeIconBtn
      >
        <AkIcon @iconName='close' />
      </AkIconButton>
    </AkAppbar>

    <AkStack
      @width='full'
      @justifyContent='space-between'
      @alignItems='center'
      class='px-3 py-4'
    >
      <AkStack @direction='column' {{style maxWidth='340px'}}>
        <AkTypography @fontWeight='bold'>
          Add Appknox Projects to Inventory by default
        </AkTypography>

        <AkTypography @variant='body2' @color='neutral'>
          Lorem ipsum dolor sit amet consectetur. At suspendisse et orci risus
          non sed. Mauris dui tincidunt
        </AkTypography>
      </AkStack>

      <AkToggle @size='small' />
    </AkStack>

    <AkDivider @color='dark' />
  </AkStack>
</AkDrawer>