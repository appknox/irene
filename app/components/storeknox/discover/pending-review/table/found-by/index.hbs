{{#if @loading}}
  <AkSkeleton @width='120px' @height='16px' />
{{else}}
  <AkStack @alignItems='center' @spacing='0.5'>
    <AkTypography>
      {{@data.foundBy}}
    </AkTypography>

    {{#if @data.addedBy}}
      <AkTooltip @placement='bottom' @arrow={{true}} @color='light'>
        <:tooltipContent>
          <AkStack @spacing='0.5'>
            <AkIcon @iconName='person' />

            <AkTypography @color='inherit'>
              {{@data.addedBy.email}}
            </AkTypography>
          </AkStack>
        </:tooltipContent>

        <:default>
          <AkIcon @iconName='info' local-class='info-icon' />
        </:default>
      </AkTooltip>
    {{/if}}
  </AkStack>
{{/if}}