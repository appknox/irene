<form {{on 'submit' this.discoverApp}}>
  <AkStack>
    <div local-class='search-input-container-width'>
      <AkTextField
        @placeholder={{t 'storeknox.searchQuery'}}
        @value={{this.searchQuery}}
      >
        <:rightAdornment>
          {{#if this.discoverClicked}}
            <AkStack
              @alignItems='center'
              local-class='close-search-text'
              {{on 'click' this.clearSearch}}
            >
              <AkIcon @iconName='close' />

              <AkTypography @underline='always'>
                {{t 'clear'}}
              </AkTypography>
            </AkStack>
          {{else}}
            <AkIcon @iconName='search' @color='textSecondary' />
          {{/if}}
        </:rightAdornment>
      </AkTextField>
    </div>

    <AkButton @type='submit' @disabled={{not this.searchQuery}}>
      {{t 'storeknox.discoverHeader'}}
    </AkButton>
  </AkStack>
</form>

{{#if this.discoverClicked}}
  <Storeknox::Discover::Results::Table @queryParams={{this.args.queryParams}} />
{{else}}
  <Storeknox::Discover::Results::Empty />
{{/if}}