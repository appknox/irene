<AkButton
  @variant='outlined'
  @disabled={{@disabled}}
  @color={{if @needsAction 'primary'}}
  local-class='action-button-root
  {{if this.isArchived "archived"}}
  {{if @needsAction "needs-action"}}
  {{if @featureInProgress "feature-in-progress"}}
  {{if @statusIsInitializing "status-initializing"}}'
  ...attributes
>
  <:leftIcon>
    <AkIcon
      @iconName={{if @featureInProgress 'auto-fix-high' 'info'}}
      @color='inherit'
      data-test-storeknoxInventoryDetails-actionBtn-leftIcon
    />
  </:leftIcon>

  <:default>
    {{@label}}
  </:default>

  <:rightIcon>
    {{#unless @hideRightIcon}}
      {{#if @statusIsInitializing}}
        <AkLoader
          @size={{16}}
          data-test-storeknoxInventoryDetails-actionBtn-rightIconLoader
        />
      {{else}}
        <AkIcon
          @iconName='arrow-outward'
          @color='textPrimary'
          {{style fontSize='1.2857em !important'}}
          data-test-storeknoxInventoryDetails-actionBtn-rightIcon
        />
      {{/if}}
    {{/unless}}
  </:rightIcon>
</AkButton>