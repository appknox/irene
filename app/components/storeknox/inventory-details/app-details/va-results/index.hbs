      >
        <span local-class='indicator medium'></span>

        <AkTypography @fontWeight='medium' @variant='body2'>MEDIUM - 8</AkTypography>
      </AkStack>
    </:tooltipContent>

    <:default>
      <div local-class='bar medium'></div>
    </:default>
  </AkTooltip>

  <AkTooltip
    @arrow={{true}}
    @placement='bottom'
    @color='light'
    {{style width=(concat this.vaResults.low '%')}}
  >
