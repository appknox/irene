        <AkTypography @fontWeight='medium' @variant='body2'>LOW - 8</AkTypography>
      </AkStack>
    </:tooltipContent>

    <:default>
      <div local-class='bar low'></div>
    </:default>
  </AkTooltip>

  <AkTooltip
    @arrow={{true}}
    @placement='bottom'
    @color='light'
    {{style width=(concat this.vaResults.passed '%')}}
  >
    <:tooltipContent>
      <AkStack
        @alignItems='center'
