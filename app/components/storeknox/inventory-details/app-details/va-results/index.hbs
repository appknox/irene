<div local-class='summary-bars-container'>
  <AkTooltip
    @arrow={{true}}
    @placement='bottom'
    @color='light'
    {{style width=(concat this.vaResults.critical '%')}}
  >
    <:tooltipContent>
      <AkStack
        @alignItems='center'
        @justifyContent='center'
        @spacing='1'
        class='p-1'
      >
        <span local-class='indicator critical'></span>

        <AkTypography @fontWeight='medium' @variant='body2'>CRITICAL - 8</AkTypography>
      </AkStack>
    </:tooltipContent>

    <:default>
      <div local-class='bar critical'></div>
    </:default>
  </AkTooltip>

  <AkTooltip
    @arrow={{true}}
    @placement='bottom'
    @color='light'
    {{style width=(concat this.vaResults.high '%')}}
  >
    <:tooltipContent>
