        @alignItems='center'
        @justifyContent='center'
        @spacing='1'
        class='p-1'
      >
        <span local-class='indicator high'></span>

        <AkTypography @fontWeight='medium' @variant='body2'>HIGH - 6</AkTypography>
      </AkStack>
    </:tooltipContent>

    <:default>
      <div local-class='bar high'></div>
    </:default>
  </AkTooltip>

  <AkTooltip
    @arrow={{true}}
    @placement='bottom'
    @color='light'
    {{style width=(concat this.vaResults.medium '%')}}
  >
