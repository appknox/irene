      >
        <span local-class='indicator passed'></span>

        <AkTypography @fontWeight='medium' @variant='body2'>PASSED - 8</AkTypography>
      </AkStack>
    </:tooltipContent>

    <:default>
      <div local-class='bar passed'></div>
    </:default>
  </AkTooltip>
</div>