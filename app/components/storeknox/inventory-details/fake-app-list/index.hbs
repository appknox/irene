<div
  local-class='fake-app-list-root
  {{if @skInventoryApp.isArchived "archived"}}
  '
>
  <AkTabs as |Akt|>
    {{#each this.tabItems as |item|}}
      <Akt.tabItem
        @id={{item.id}}
        @hasBadge={{true}}
        @badgeCount={{item.count}}
        @route={{item.route}}
        @model={{@skInventoryApp.id}}
        @currentWhen={{item.route}}
        @indicatorVariant='shadow'
        data-test-storeknoxFakeAppsFakeAppDetails-fakeApp-tab='{{item.id}}'
      >
        {{item.label}}
      </Akt.tabItem>
    {{/each}}
  </AkTabs>
</div>