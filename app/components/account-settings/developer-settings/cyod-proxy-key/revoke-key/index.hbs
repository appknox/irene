<AkIconButton @size='small' {{on 'click' this.openConfirmBox}}>
  <AkIcon @iconName='delete' @color='error' />
</AkIconButton>

<ConfirmBox
  @isActive={{this.showConfirmBox}}
  @description={{t 'cyodProxyKeyRevokeWarning'}}
  @disabled={{this.revokeKey.isRunning}}
  @confirmText={{t 'cyodProxyKeyRevokeConfirm'}}
  @confirmAction={{perform this.revokeKey}}
  @cancelAction={{this.closeConfirmBox}}
/>
