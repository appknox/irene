<AkStack
  @bgColor='white'
  @width='full'
  local-class='account-settings-tabs-root'
>
  <AkTabs class='w-full' as |Akt|>
    {{#each this.tabs as |item|}}
      <Akt.tabItem
        @id={{item.route}}
        @route={{item.route}}
        @currentWhen={{item.activeRoutes}}
      >
        {{item.label}}
      </Akt.tabItem>
    {{/each}}
  </AkTabs>
</AkStack>