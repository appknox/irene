<FreestyleSection @name='Date Picker'>
  <FreestyleUsage @slug='ak-date-picker-basic' @title='Basic' @source='<AkDatePicker
  @selected=\{{this.selected}}
  @onSelect=\{{this.onSelect}}
  @quickSelectOptions=\{{array "clear"}}
>
  <AkButton>Open date picker</AkButton>
</AkDatePicker>'>
    <AkTypography @color='textSecondary' @gutterBottom={{true}}>Click the button to open the date picker</AkTypography>
    <AkDatePicker::FreestyleDemo />
  </FreestyleUsage>
</FreestyleSection>
