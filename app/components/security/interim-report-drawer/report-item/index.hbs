<AkList::Item
  ...attributes
  @divider={{true}}
  {{style padding='0.7857em 1.4285em' minWidth='400px'}}
  data-test-securityInterimReportDrawer-reportListItem
  as |li|
>
  <li.leftIcon data-test-securityInterimReportDrawer-leftIcon>
    {{#let (component @reportDetails.iconComponent) as |Icon|}}
      <Icon />
    {{/let}}
  </li.leftIcon>

  <AkStack @direction='column' @width='full' @spacing='0.5' class='pl-1'>
    <AkStack @direction='row' @spacing='0.5'>
      <AkTypography
        @variant='subtitle1'
        data-test-securityInterimReportDrawer-primaryText
      >
        {{@reportDetails.primaryText}}
      </AkTypography>

      <AkTooltip @arrow={{true}} @placement='bottom'>
        <:default>
          <AkIcon @iconName='info' @color='textSecondary' />
        </:default>

        <:tooltipContent>
          <AkTypography @color='inherit'>
            Generated on
            {{@reportDetails.generatedOnDateTime}}
          </AkTypography>
          <AkTypography @color='inherit'>
            Generated by
            {{@reportDetails.generatedBy}}
          </AkTypography>
        </:tooltipContent>
      </AkTooltip>
    </AkStack>

    {{#if this.showGeneratingText}}
      <AkTypography
        @color='textSecondary'
        data-test-securityInterimReportDrawer-generatingText
      >
        {{t 'generating'}}...
      </AkTypography>
    {{else}}
      <AkStack @alignItems='center' @spacing='0.5'>
        <AkTypography
          data-test-securityInterimReportDrawer-secondaryText
          class='posthog-sensitive'
        >
          {{@reportDetails.secondaryText}}
        </AkTypography>

        <AkClipboard
          @onSuccess={{this.handleCopySuccess}}
          @onError={{this.handleCopyError}}
          as |cb|
        >
          <AkIconButton
            id={{cb.triggerId}}
            @size='small'
            data-clipboard-text={{@reportDetails.copyText}}
          >
            <AkIcon @iconName='content-copy-outline' @color='primary' />
          </AkIconButton>
        </AkClipboard>
      </AkStack>
    {{/if}}
  </AkStack>

  <li.rightIcon>
    {{#if this.showDownloadButton}}
      <AkIconButton
        disabled={{this.reportIsDownloading}}
        {{on 'click' this.getReport}}
        data-test-securityInterimReportDrawer-reportDownloadBtn
      >
        {{#if this.reportIsDownloading}}
          <AkLoader
            @size={{16}}
            data-test-securityInterimReportDrawer-reportDownloadBtn-loadingIcon
          />
        {{else}}
          <AkIcon
            @iconName='download'
            data-test-securityInterimReportDrawer-reportDownloadBtn-icon
          />
        {{/if}}
      </AkIconButton>
    {{/if}}
  </li.rightIcon>
</AkList::Item>

<AkStack class='px-3 py-2' @justifyContent='space-between' @width='full'>
  <AkTypography
    @fontWeight='bold'
    data-test-securityInterimReportDrawer-reportItem-title
  >
    Enable for customer
  </AkTypography>

  <AkToggle
    @checked={{this.enabledForCustomer}}
    @size='small'
    @onChange={{this.openToggleConfirmBox}}
    {{style margin='0'}}
    data-test-securityInterimReportDrawer-reportItem-toggle
  />
</AkStack>

<AkDivider />

{{#if this.isNewReportAvailable}}
  <AkStack class='px-3 py-2' @direction='column' @spacing='1'>
    <AkTypography>
      The security dashboard has updated results for the manual scan.
      <br />
      Please click the button below to generate the latest interim report.
    </AkTypography>

    <AkButton
      @loading={{@regenerateReportTaskIsRunning}}
      {{on 'click' @regenerateReport}}
      data-test-securityInterimReportDrawer-reportItem-newReportBtn
    >
      Regenerate Report
    </AkButton>
  </AkStack>

  <AkDivider />
{{/if}}

<ConfirmBox
  @isActive={{this.toggleConfirmBoxOpen}}
  @description={{this.toggleConfirmBoxDescription}}
  @cancelAction={{this.closeToggleConfirmBox}}
  @confirmAction={{this.toggleEnabledForCustomer}}
  @confirmText='Yes, Proceed'
  @cancelText='No'
  @blurOverlay={{true}}
/>