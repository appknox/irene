<AkStack>
  {{#if @clickable}}
    <AkStack
      @alignItems='center'
      local-class='powered-by-chip clickable {{if (eq @variant "outlined") "outlined"}}'
      {{on 'click' this.openAIDrawer}}
      ...attributes
    >
      <AkIcon @iconName='network-intel-node' local-class='icon' />

      <AkTypography local-class='text'>
        {{this.chipText}}
      </AkTypography>
    </AkStack>
  {{else}}
    <AkStack
      @alignItems='center'
      local-class='powered-by-chip {{if (eq @variant "outlined") "outlined"}}'
      ...attributes
    >
      <AkIcon @iconName='network-intel-node' local-class='icon' />

      <AkTypography local-class='text'>
        {{this.chipText}}
      </AkTypography>
    </AkStack>
  {{/if}}

  <PoweredByAi::Drawer
    @aiDrawerOpen={{this.aiDrawerOpen}}
    @onClose={{this.closeAiDrawer}}
    @info={{@drawerInfo}}
    @variant={{@variant}}
  >
    <:content>
      {{yield to='content'}}
    </:content>
  </PoweredByAi::Drawer>
</AkStack>