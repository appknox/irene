<AkButton
  @variant='outlined'
  @disabled={{this.isTriggerDisabled}}
  @loading={{this.triggerValidation.isRunning}}
  {{on 'click' (perform this.triggerValidation)}}
  data-test-fileCopilotValidationBtn
>
  <:leftIcon>
    <AkIcon @iconName='play-arrow' data-test-fileCopilotValidationBtn-icon />
  </:leftIcon>

  <:default>
    Run KnoxIQ
  </:default>
</AkButton>
