<AkButton
  @variant='outlined'
  @disabled={{this.isTriggerDisabled}}
  @loading={{or this.triggerValidation.isRunning this.isValidationInProgress}}
  {{on 'click' (perform this.triggerValidation)}}
  data-test-fileCopilotValidationBtn
>
  <:leftIcon>
    <AkIcon @iconName='play-arrow' data-test-fileCopilotValidationBtn-icon />
  </:leftIcon>

  <:default>
    {{#if this.isValidationInProgress}}
      KnoxIQ Running...
    {{else}}
      Run KnoxIQ
    {{/if}}
  </:default>
</AkButton>
