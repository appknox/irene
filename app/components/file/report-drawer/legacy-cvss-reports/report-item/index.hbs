<AkList::Item
  ...attributes
  @divider={{true}}
  {{style padding='0.7857em 1.4285em'}}
  data-test-legacyCvssReportListItem
  as |li|
>
  <li.leftIcon data-test-legacyCvssReportListItem-leftIcon>
    {{#let (component @reportDetails.iconComponent) as |Icon|}}
      <Icon />
    {{/let}}
  </li.leftIcon>

  <AkStack @direction='column' @width='full' @spacing='0.5' class='pl-1'>
    <AkTypography @variant='subtitle1' data-test-legacyCvssReportListItem-primaryText>
      {{@reportDetails.primaryText}}
    </AkTypography>

    {{#if this.showGeneratingText}}
      <AkTypography
        @color='textSecondary'
        data-test-legacyCvssReportListItem-generatingText
      >
        {{t 'generating'}}...
      </AkTypography>
    {{else}}
      <AkStack @alignItems='center' @spacing='0.5'>
        <AkTypography
          class='posthog-sensitive'
          data-test-legacyCvssReportListItem-secondaryText
        >
          {{@reportDetails.secondaryText}}
        </AkTypography>

        {{#if @reportDetails.copyText}}
          <AkClipboard
            @onSuccess={{this.handleCopySuccess}}
            @onError={{this.handleCopyError}}
            as |cb|
          >
            <AkIconButton
              id={{cb.triggerId}}
              @size='small'
              data-test-legacyCvssReportListItem-passCopyBtn
              data-clipboard-text={{@reportDetails.copyText}}
            >
              <AkIcon @iconName='content-copy-outline' @color='primary' />
            </AkIconButton>
          </AkClipboard>
        {{/if}}
      </AkStack>
    {{/if}}

    <AkTypography
      @variant='body2'
      @color='textSecondary'
      data-test-legacyCvssReportListItem-generatedOnDateTime
    >
      {{@reportDetails.generatedOnDateTime}}
    </AkTypography>
  </AkStack>

  <li.rightIcon>
    {{#if this.showDownloadButton}}
      <AkIconButton
        disabled={{this.reportIsDownloading}}
        {{on 'click' this.getReport}}
        data-test-legacyCvssReportListItem-reportDownloadBtn
      >
        {{#if this.reportIsDownloading}}
          <AkLoader
            @size={{16}}
            data-test-legacyCvssReportListItem-reportDownloadBtn-loadingIcon
          />
        {{else}}
          <AkIcon
            @iconName='download'
            data-test-legacyCvssReportListItem-reportDownloadBtn-icon
          />
        {{/if}}
      </AkIconButton>
    {{/if}}
  </li.rightIcon>
</AkList::Item>
