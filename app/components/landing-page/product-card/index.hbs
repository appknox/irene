<AkStack
  data-test-landingPage-productCard
  @direction='column'
  local-class='product-card-container'
>
  {{#if (eq @name 'Storeknox')}}
    <AkSvg::StoreknoxBgImg />
  {{else}}
    <AkSvg::AppknoxBgImg />
  {{/if}}

  <AkStack @direction='column' @spacing='4' local-class='product-card-content'>
    <AkStack @direction='column' @spacing='1'>
      {{#if (eq @name 'Storeknox')}}
        <AkSvg::SmIndicator
          data-test-landingPage-productCard-icon-sm
          local-class='product-icon'
        />
      {{else}}
        <AkSvg::VpIndicator
          data-test-landingPage-productCard-icon-vp
          local-class='product-icon'
        />
      {{/if}}
      <AkTypography
        data-test-landingPage-productCard-title
        @variant='h6'
        @fontWeight='bold'
      >
        {{@name}}
      </AkTypography>
      <AkTypography @variant='subtitle2' @fontWeight='regular'>
        {{@description}}
      </AkTypography>
    </AkStack>

    <AkStack @direction='row' @spacing='1' @alignItems='center'>
      <AkLink
        data-test-landingPage-productCard-link
        @route={{this.route}}
        @underline='always'
        @fontWeight='medium'
      >
        {{@linkText}}
      </AkLink>

      <AkIcon @iconName='north-east' @size='small' @color='primary' />
    </AkStack>
  </AkStack>
</AkStack>