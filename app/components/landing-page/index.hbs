<AkStack
  data-test-landingPage
  @direction='column'
  @alignItems='center'
  local-class='landing-page-container'
>
  <AkStack
    @direction='column'
    @width='10/12'
    local-class='landing-page-content'
  >
    <AkStack
      data-test-landingPage-appLogo
      local-class='logo-container'
      class='py-2'
    >
      <AuthAssets />
    </AkStack>

    <AkStack class='py-2' @width='full' @direction='column' @spacing='0.5'>
      <AkTypography @variant='h5' @fontWeight='regular'>
        {{t 'selectThePath'}}
      </AkTypography>

      <AkStack
        @direction='row'
        @width='full'
        @justifyContent='space-between'
        @alignItems='center'
      >

        <AkTypography
          data-test-landingPage-title
          @variant='h2'
          @fontWeight='bold'
        >
          {{t 'toSecureYourMobileApps'}}
        </AkTypography>

        <AkButton
          @variant='outlined'
          @color='neutral'
          local-class='logout-button'
          {{on 'click' this.invalidateSession}}
          data-test-landingPage-logoutBtn
        >
          <:leftIcon>
            <AkIcon @iconName='logout' />
          </:leftIcon>

          <:default>
            {{t 'logout'}}
          </:default>
        </AkButton>
      </AkStack>
    </AkStack>

    <AkDivider @color='dark' class='mb-2' />

    <AkStack class='py-1' @direction='row' @spacing='4' @flexWrap='wrap'>
      <LandingPage::ProductCard
        @name={{t 'appknox'}}
        @description={{t 'appknoxDesc'}}
        @linkText={{t 'takeMeToDashboard'}}
        @route='authenticated.dashboard.projects'
      />

      {{#if this.isStoreknoxEnabled}}
        <LandingPage::ProductCard
          @name={{t 'storeknox'}}
          @description={{t 'storeknoxDesc'}}
          @linkText={{t 'takeMeToDashboard'}}
          @route='authenticated.storeknox'
        />
      {{/if}}
    </AkStack>
  </AkStack>
</AkStack>