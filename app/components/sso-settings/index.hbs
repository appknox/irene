<div local-class='sso-settings-container'>
  <AkTypography data-test-ssoSetting-title @variant='h5' @gutterBottom={{true}}>
    {{t 'singleSignOn'}}
  </AkTypography>

  <AkTabs class='w-full mb-2' as |Akt|>
    {{#each this.tabItems as |item|}}
      <Akt.tabItem
        @id={{item.id}}
        @isActive={{eq this.activeTab item.id}}
        @buttonVariant={{true}}
        @onTabClick={{this.onTabClick}}
      >
        {{item.label}}
      </Akt.tabItem>
    {{/each}}
  </AkTabs>

  {{#let (component this.activeTabComponent) as |Component|}}
    <Component
      @organization={{@organization}}
      @user={{@user}}
      @sso={{this.sso}}
    />
  {{/let}}

  {{#if this.hasSamlOrOidc}}
    <div class='mt-3' local-class='bordered-box'>
      <div local-class='bordered-box-section'>
        <AkTypography data-test-ssoSetting-ssoTitle @variant='subtitle1'>
          {{t 'ssoAuthentication'}}
        </AkTypography>
      </div>

      <AkStack
        @alignItems='center'
        @spacing='0.5'
        local-class='bordered-box-section'
      >
        <AkFormControlLabel
          data-test-ssoSetting-ssoSwitchLabel
          @labelTypographyVariant='h6'
          @label='{{t "enable"}} {{t "ssoAuthentication"}}'
          @disabled={{this.toggleSSOEnable.isRunning}}
          as |fcl|
        >
          <AkToggle
            data-test-ssoSetting-ssoSwitch
            @disabled={{fcl.disabled}}
            @checked={{this.sso.enabled}}
            @onChange={{perform this.toggleSSOEnable}}
            @size='small'
          />
        </AkFormControlLabel>

        <AkTypography
          data-test-ssoSetting-ssoEnableDesc
          @tag='span'
          @variant='body2'
          @color='textSecondary'
        >
          ({{t 'ssoEnableDesc'}})
        </AkTypography>
      </AkStack>

      {{#if this.sso.enabled}}
        <AkStack
          @alignItems='center'
          @spacing='0.5'
          local-class='bordered-box-section'
        >
          <AkIcon
            @color='textPrimary'
            @iconName='subdirectory-arrow-right'
            class='ml-1'
          />

          <AkFormControlLabel
            data-test-ssoSetting-ssoEnforceLabel
            @labelTypographyVariant='h6'
            @label='{{t "ssoEnforce"}}'
            @disabled={{this.toggleSSOEnforce.isRunning}}
            as |fcl|
          >
            <AkCheckbox
              data-test-ssoSetting-ssoEnforceCheckbox
              @disabled={{fcl.disabled}}
              @checked={{this.sso.enforced}}
              @onChange={{perform this.toggleSSOEnforce}}
            />
          </AkFormControlLabel>

          <AkTypography
            data-test-ssoSetting-ssoEnforceDesc
            @tag='span'
            @variant='body2'
            @color='textSecondary'
          >
            ({{t 'ssoEnforceDesc'}})
          </AkTypography>
        </AkStack>
      {{/if}}
    </div>
  {{/if}}
</div>