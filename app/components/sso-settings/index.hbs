<div local-class='sso-settings-container'>
  <AkTypography
    data-test-ssoSettings-title
    @variant='h5'
    @gutterBottom={{true}}
  >
    {{t 'singleSignOn'}}
  </AkTypography>

  <AkTabs data-test-ssoSettings-tabs class='w-full mb-2' as |Akt|>
    {{#each this.tabItems as |item|}}
      <Akt.tabItem
        data-test-ssoSettings-tab='{{item.id}}'
        @id={{item.id}}
        @isActive={{eq this.activeTab item.id}}
        @buttonVariant={{true}}
        @onTabClick={{this.onTabClick}}
      >
        {{item.label}}
      </Akt.tabItem>
    {{/each}}
  </AkTabs>

  {{#let (component this.activeTabComponent) as |Component|}}
    {{#if this.hasOidcOrSaml}}
      {{! Show steps in the opposite tab to help switch }}
      {{#if (and this.hasOidc this.isSamlTabActive)}}
        <SsoSettings::WarningBanner @text={{t 'ssoSettings.oidc.warning'}} />

        <SsoSettings::StepsDisplay
          @title={{t 'ssoSettings.oidc.title'}}
          @steps={{this.oidcSteps}}
        />
      {{else if (and this.hasSaml this.isOidcTabActive)}}
        <SsoSettings::WarningBanner @text={{t 'ssoSettings.saml.warning'}} />

        <SsoSettings::StepsDisplay
          @title={{t 'ssoSettings.saml.title'}}
          @steps={{this.samlSteps}}
        />
      {{else}}
        {{! Show actual data if current tab matches and SSO exists }}
        <Component
          @organization={{@organization}}
          @user={{@user}}
          @sso={{this.sso}}
          @idpMetadata={{this.idpMetadata}}
          @providers={{this.providers}}
          @deleteProvider={{this.deleteProvider}}
          @deleteIdpMetadata={{this.deleteIdpMetadata}}
          @refreshSsoData={{this.refreshSsoData}}
        />
      {{/if}}
    {{else}}
      {{! If no SSO is configured, show setup component directly }}
      <Component
        @organization={{@organization}}
        @user={{@user}}
        @sso={{this.sso}}
        @idpMetadata={{this.idpMetadata}}
        @providers={{this.providers}}
        @deleteProvider={{this.deleteProvider}}
        @deleteIdpMetadata={{this.deleteIdpMetadata}}
        @refreshSsoData={{this.refreshSsoData}}
      />
    {{/if}}
  {{/let}}
</div>