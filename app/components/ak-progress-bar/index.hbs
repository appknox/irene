<AkStack
  @width='full'
  local-class='root'
  {{style height=@height}}
  data-test-ak-progress-bar
>
  {{#each this.renderedSegments as |seg|}}
    <div
      local-class='segment {{if seg.striped "segment--striped"}}'
      data-segment={{seg.key}}
      data-test-ak-progress-bar-segment={{seg.key}}
      {{style width=(concat seg.pct '%') background=seg.background}}
    />
  {{/each}}
</AkStack>