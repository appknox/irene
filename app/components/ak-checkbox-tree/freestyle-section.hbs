<FreestyleSection @name='Checkbox Tree'>
  <FreestyleUsage @slug='ak-checkbox-tree-basic' @title='Basic' @source='<AkCheckboxTree
  @treeData=\{{this.treeData}}
  @expanded=\{{this.expanded}}
  @cascade=\{{true}}
  @checked=\{{this.checked}}
  @onCheck=\{{this.onCheck}}
  @onExpand=\{{this.onExpand}}
/>'>
    <AkCheckboxTree::FreestyleDemo />
  </FreestyleUsage>
</FreestyleSection>
